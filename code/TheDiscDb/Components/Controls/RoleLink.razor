@if (Item != null && IsMediaItem)
{
    var filteredItems = MediaItem?.MediaItemGroups.Where(g => g?.Group?.Name != null && g.Group.Name.Equals(this.Text, StringComparison.OrdinalIgnoreCase) && g?.Role != null && g.Role.Equals(this.Role, StringComparison.OrdinalIgnoreCase)).ToList();
    if (filteredItems == null || filteredItems.Count == 0)
    {
        <span class="metadata-chip">@this.Text</span>
    }
    else
    {
        var group = filteredItems.First().Group;
        @if(group != null)
        {
            <a href="/g/@group.Slug" class="metadata-chip">@group.Name</a>
        }
    }
}