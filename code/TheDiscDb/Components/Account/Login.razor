@page "/Account/Login"

@rendermode InteractiveServer

<PageTitle>Sign In — TheDiscDb</PageTitle>
<HeadContent>
    <meta name="description" content="Sign in to TheDiscDb to contribute disc information, manage your submissions, and help build the community database." />
    <link rel="canonical" href="https://thediscdb.com/account/login" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet" />
</HeadContent>

<div class="login-page">
    <div class="login-scene">
        <div class="login-ring login-ring--1"></div>
        <div class="login-ring login-ring--2"></div>
        <div class="login-ring login-ring--3"></div>
        <div class="login-glow"></div>
    </div>

    <div class="login-card">
        <h1 class="login-card__title"><span>Log in</span></h1>
        <p class="login-card__subtitle">Sign in to contribute, curate, and explore the community disc database.</p>

        <form action="Account/PerformExternalLogin" method="post" class="login-card__form">
            <AntiforgeryToken />
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

            @foreach (var provider in externalLogins)
            {
                <button type="submit" name="provider" value="@provider.Name"
                        class="login-btn login-btn--@(provider.Name.ToLowerInvariant())"
                        title="Continue with @provider.DisplayName">
                    @if (provider.Name.Equals("GitHub", StringComparison.OrdinalIgnoreCase))
                    {
                        <svg class="login-btn__icon" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                        </svg>
                    }
                    else if (provider.Name.Equals("Google", StringComparison.OrdinalIgnoreCase))
                    {
                        <svg class="login-btn__icon" viewBox="0 0 24 24">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                    }
                    else if (provider.Name.Equals("Microsoft", StringComparison.OrdinalIgnoreCase))
                    {
                        <svg class="login-btn__icon" viewBox="0 0 21 21">
                            <rect x="1" y="1" width="9" height="9" fill="#f25022"/>
                            <rect x="11" y="1" width="9" height="9" fill="#7fba00"/>
                            <rect x="1" y="11" width="9" height="9" fill="#00a4ef"/>
                            <rect x="11" y="11" width="9" height="9" fill="#ffb900"/>
                        </svg>
                    }
                    else
                    {
                        <svg class="login-btn__icon" viewBox="0 0 24 24" fill="currentColor" opacity="0.7">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                        </svg>
                    }
                    <span class="login-btn__label">Login with @provider.DisplayName</span>
                </button>
            }
        </form>

        <p class="login-card__footer">Join the community building the definitive disc database.</p>
    </div>
</div>