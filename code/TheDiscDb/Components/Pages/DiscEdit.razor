@page "/{type}/{slug}/releases/{releaseSlug}/discs/{slugOrIndex}/edit"
@page "/boxset/{slug}/discs/{slugOrIndex}/edit"
@using TheDiscDb.InputModels

@rendermode InteractiveServer
@inherits TheDiscDb.Components.AuthenticatedComponentBase

<PageTitle>Edit Disc - TheDiscDb</PageTitle>

@if (Item == null || Release == null || Disc == null)
{
    <div class="alert alert-warning">Disc not found.</div>
}
else
{
    <TheDiscDb.Client.Controls.Breadcrumb Items="@GetBreadcrumbs()" PrimaryText="Edit Disc" />

    @if (!string.IsNullOrEmpty(submitMessage))
    {
        <div class="alert @(submitSuccess ? "alert-success" : "alert-danger")">@submitMessage</div>
    }

    @if (!isReviewing)
    {
        <h1>Suggest Edits for @Disc.GetFullName()</h1>
        <p class="text-muted">
            Edit the disc details below. Your changes will be reviewed before being applied.
        </p>

        <section class="info-grid single-column">
            <div class="mb-4">
                <h3>Disc Details</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" @bind="editName" @bind:event="oninput" placeholder="Disc name" />
                        @if (string.IsNullOrWhiteSpace(editName))
                        {
                            <div class="text-danger small">Name is required.</div>
                        }
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Format</label>
                        <select class="form-select" @bind="editFormat">
                            <option value="@DiscFormatConstants.Uhd">@DiscFormatConstants.FourK</option>
                            <option value="@DiscFormatConstants.BluRay">@DiscFormatConstants.BluRay</option>
                            <option value="@DiscFormatConstants.Dvd">@DiscFormatConstants.Dvd</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Content Hash</label>
                        @if (CanAddContentHash)
                        {
                            <input type="text" class="form-control" @bind="editContentHash" @bind:event="oninput" placeholder="32-character disc hash" />
                            @if (ContentHashInputInvalid)
                            {
                                <div class="text-danger small">Content hash must be 32 hexadecimal characters.</div>
                            }
                            else
                            {
                                <div class="form-text">Optional. Add the disc's content hash if you know it.</div>
                            }
                        }
                        else
                        {
                            <input type="text" class="form-control" value="@originalContentHash" readonly disabled />
                            <div class="form-text">Set during import; can't be changed.</div>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(originalGlobalDiscId))
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">Disc ID</label>
                            <input type="text" class="form-control" value="@originalGlobalDiscId" readonly disabled />
                            <div class="form-text">Globally-stable Disc ID (AACS/DVD). Added via a Disc ID contribution.</div>
                        </div>
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="ShowReview" disabled="@(!HasChanges() || !IsValid())">
                    Review Suggested Changes
                </button>
                <a href="@GetDiscUrl()" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </section>
    }
    else
    {
        <h1>Review Your Disc Changes</h1>
        <p class="text-muted">These changes will be submitted for review by an admin.</p>

        <section class="info-grid single-column">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Field</th>
                        <th>Current</th>
                        <th>Proposed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var diff in pendingDiffs)
                    {
                        <tr class="table-warning">
                            <td><strong>@diff.FieldName</strong></td>
                            <td class="text-muted">@(diff.CurrentValue ?? "—")</td>
                            <td><strong>@(diff.ProposedValue ?? "—")</strong></td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (pendingDiffs.Count == 0)
            {
                <div class="alert alert-info">No changes detected.</div>
            }

            @if (pendingDiffs.Count > 0)
            {
                <div class="mb-3">
                    <label>Summary <span class="text-muted">(optional — briefly describe your changes)</span></label>
                    <input type="text" class="form-control" @bind="summary" />
                </div>
            }

            <div class="d-flex gap-2">
                @if (pendingDiffs.Count > 0 && !submitSuccess)
                {
                    <button type="button" class="btn btn-primary" disabled="@isSubmitting" @onclick="HandleSubmit">
                        @(isSubmitting ? "Submitting…" : "Submit Changes")
                    </button>
                }
                @if (!submitSuccess)
                {
                    <button type="button" class="btn btn-outline-secondary" @onclick="BackToEdit">← Back to Edit</button>
                }
            </div>
        </section>
    }
}
