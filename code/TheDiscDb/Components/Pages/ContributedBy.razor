@page "/contributedBy/{username}"
@using TheDiscDb.Services.Achievements

<PageTitle>Releases by @Username - TheDiscDb</PageTitle>
<HeadContent>
    <meta name="description" content="Browse all Blu-ray, 4K UHD, and DVD releases contributed by @Username to TheDiscDb — the community disc database." />
    <link rel="canonical" href="https://thediscdb.com/contributedBy/@Uri.EscapeDataString(Username ?? "")" />
    <meta property="og:title" content="Releases by @Username - TheDiscDb" />
    <meta property="og:description" content="Browse all releases contributed by @Username to TheDiscDb." />
    <meta property="og:url" content="https://thediscdb.com/contributedBy/@Uri.EscapeDataString(Username ?? "")" />
    <meta property="og:type" content="website" />
</HeadContent>

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="@Username" Items='[("Home", "/"), ("Contribute", "/contribute"), ("Leaderboard", "/leaderboard")]' />

<div class="contribute-layout">
    <div class="page-header">
        <h1>Contributions by <span class="page-header__accent">@Username</span></h1>
        <div class="page-header__sub">@(releases?.Count ?? 0) contribution@(releases?.Count == 1 ? "" : "s") and growing!</div>
    </div>

    @if (profile != null && (profile.Earned.Count > 0 || profile.InProgress.Count > 0))
    {
        <section class="achievements">
            <div class="achievements__header">
                <h2>Achievements</h2>
                <span class="achievements__level" title="@profile.TotalPoints points">@profile.Level</span>
            </div>

            @if (profile.Earned.Count > 0)
            {
                <div class="achievements__grid">
                    @foreach (var earned in profile.Earned)
                    {
                        <div class="achievement" title="@earned.Definition.Description">
                            <BadgeIcon Icon="@earned.Definition.Icon"
                                       Tier="earned.Definition.Tier"
                                       Title="@earned.Definition.Name"
                                       Earned="true" />
                            <span class="achievement__name">@earned.Definition.Name</span>
                        </div>
                    }
                </div>
            }

            @if (profile.InProgress.Count > 0)
            {
                <h3 class="achievements__subhead">In progress</h3>
                <div class="achievements__progress-list">
                    @foreach (var item in profile.InProgress)
                    {
                        <div class="achievement-progress" title="@item.Definition.Description">
                            <BadgeIcon Icon="@item.Definition.Icon"
                                       Tier="item.Definition.Tier"
                                       Title="@item.Definition.Name"
                                       Earned="false" />
                            <div class="achievement-progress__body">
                                <span class="achievement-progress__name">@item.Definition.Name</span>
                                <div class="achievement-progress__bar">
                                    <div class="achievement-progress__fill pw-@ProgressBucket(item.Percent)"></div>
                                </div>
                                <span class="achievement-progress__count">@item.Current / @item.Target</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }

    @if (errorMessage != null)
    {
        <p class="error-state">@errorMessage</p>
    }
    else if (releases != null)
    {
        <div class="media-item-list">
            @foreach (var release in releases)
            {
                <a href="/@release.MediaType/@release.MediaItemSlug" class="media-item-card" title="@release.Title">
                    @if (!string.IsNullOrEmpty(release.ImageUrl))
                    {
                        <img src="/images/@(release.ImageUrl)?width=156&height=231" width="156" height="231" alt="@release.Title" />
                    }
                    else
                    {
                        <div class="no-image-placeholder">No Image</div>
                    }
                    <span class="media-item-label">@release.Title (@release.Year)</span>
                </a>
            }
        </div>

        @if (!releases.Any())
        {
            <p class="empty-state">No releases found for this contributor.</p>
        }
    }
    else
    {
        <p><em>Loading...</em></p>
    }
</div>
