@page "/help/suggested-edits"

<PageTitle>Suggesting Edits on TheDiscDb</PageTitle>
<HeadContent>
    <meta name="description" content="Learn how to submit suggested edits on TheDiscDb and track review status in My Changes." />
    <link rel="canonical" href="https://thediscdb.com/help/suggested-edits" />
</HeadContent>

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="Suggested Edits" Items='[("Home", "/"), ("About", "/about")]' />

<div class="contribute-layout help-page">
    <div class="page-header">
        <h1>Suggesting <span class="page-header__accent">Edits</span></h1>
        <div class="page-header__sub">
            Spot a mistake? Any signed-in user can submit corrections for review.
        </div>
    </div>

    <section class="info-grid">
        <article class="info-card">
            <h2>What you can edit</h2>
            <ul>
                <li>Release details like title, UPC, and dates.</li>
                <li>Disc names and disc format metadata.</li>
                <li>Playlist/title descriptions and title types.</li>
                <li>Chapter names and track descriptions.</li>
            </ul>
        </article>
        <article class="info-card">
            <h2>How to suggest an edit</h2>
            <ol>
                <li>Open a release, disc, or title detail page.</li>
                <li>Click the pencil icon next to the editable area.</li>
                <li>Change only the fields that need correction.</li>
                <li>Submit your suggestion for review.</li>
            </ol>
        </article>
    </section>

    <section class="info-card">
        <h2>What happens next</h2>
        <p>
            Your suggestion is added to the review queue. You can track status in
            <strong> My Changes</strong> from the user menu.
        </p>
        <p class="mb-0">
            Status flow: <strong>Pending</strong> → <strong>Approved</strong> or <strong>Rejected</strong>.
            Pending suggestions can be withdrawn before review.
        </p>
    </section>

    <section class="callout">
        <h3>Tips for useful suggestions</h3>
        <p class="mb-2">Keep changes focused and clear so reviewers can process them quickly.</p>
        <ul class="mb-0">
            <li>Prefer one clear fix per suggestion.</li>
            <li>Add concise context when the reason is not obvious.</li>
        </ul>
    </section>

    <section class="cta-row">
        <a class="btn btn-secondary" href="/changes/my">View My Changes</a>
        <a class="btn btn-primary" href="/">Browse the Database</a>
    </section>
</div>
