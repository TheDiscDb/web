@page "/{type}/{slug}/releases/{releaseSlug}/discs/{slugOrIndex}/{file}/{extension}"
@page "/{type}/{slug}/releases/{releaseSlug}/discs/{slugOrIndex}/{file}"
@page "/{type}/{slug}/discs/{slugOrIndex}/{file}"
@page "/{type}/{slug}/discs/{slugOrIndex}/{file}/{extension}"

@if (Item == null || Release == null || Disc == null || Title == null)
{
    <div>Item, Release, Disc, or Title not found</div>
}
else
{
    <PageTitle>@Item.Title - @Release.Title - TheDiscDb</PageTitle>
    <HeadContent>
        <meta name="description" content="@Title.SourceFile from @Item.Title — @Release.Title disc @Disc.Index: @Title.TitleDescription() (@Title.Duration). Audio tracks, chapters, and video stream details on TheDiscDb." />
        <link rel="canonical" href="@BuildCanonicalLink(GetDiscTitleLink(Item, Release, Disc, Title.SourceFile))" />
    </HeadContent>
    <div class="vstack">
        <TheDiscDb.Client.Controls.Breadcrumb PrimaryText="@Title.SourceFile" Items="[
            GetRootLink(this.Item),
            GetMediaItemLink(this.Item),
            GetReleaseLink(this.Item, this.Release),
            GetDiscLink(this.Item, this.Release, this.Disc)
        ]" />
        <div class="d-flex align-items-center gap-2 mb-2">
            <h1 class="mb-0">@Title.SourceFile — @Release.Title</h1>
            <a href="@GetDiscItemEditUrl()" class="btn btn-sm btn-outline-secondary" title="Suggest edits to this disc item">✏️ Suggest Edit</a>
        </div>
        <div class="metadata-card mt-3">
            <dl class="metadata-grid mb-0">
                <div class="metadata-item">
                    <dt>Source File</dt>
                    <dd>@Title.SourceFile</dd>
                </div>
                <div class="metadata-item metadata-item-wide">
                    <dt>Description</dt>
                    <dd>
                        <div class="description-with-copy">
                            <span>@Title.TitleDescription()</span>
                            <CopyButton Text="@Title.TitleDescription()"
                                        Title="Copy description"
                                        @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
                        </div>
                    </dd>
                </div>
                <div class="metadata-item">
                    <dt>Length</dt>
                    <dd>@Title.Duration</dd>
                </div>
                <div class="metadata-item">
                    <dt>Type</dt>
                    <dd>@(Title.Item?.Type ?? "—")</dd>
                </div>
                <div class="metadata-item metadata-item-wide">
                    <dt>Segment Map</dt>
                    <dd class="segment-map">@Title.SegmentMap?.Replace(",", ", ")</dd>
                </div>
                <div class="metadata-item">
                    <dt>Size</dt>
                    <dd>@Title.DisplaySize</dd>
                </div>
            </dl>
        </div>

        @if (Title.Item != null && Title.Item.Chapters != null && Title.Item.Chapters.Count > 0)
        {
            <div class="info-card mt-4">
                <div class="chapter-header">
                    <h3 class="mt-0 mb-0">Chapters</h3>
                    <div class="d-flex gap-2">
                        <TheDiscDb.Client.Controls.CopyChaptersButton
                            Chapters="@Title.Item.Chapters"
                            @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
                        <a href="@GetChapterEditUrl()" class="btn btn-sm btn-outline-secondary" title="Suggest chapter edits">✏️</a>
                    </div>
                </div>
                <ol class="chapter-list mb-0">
                    @foreach (var chapter in Title.Item.Chapters)
                    {
                        <li>@chapter.Title</li>
                    }
                </ol>
            </div>
        }
        else
        {
            <div class="info-card mt-4">
                <div class="chapter-header">
                    <h3 class="mt-0 mb-0">Chapters</h3>
                    <a href="@GetChapterEditUrl()" class="btn btn-sm btn-outline-secondary" title="Add chapter names">✏️ Add Chapters</a>
                </div>
                <p class="text-muted mb-0">No chapter names available. Know them? Suggest adding them!</p>
            </div>
        }

        @{ var trackGroups = new[] { "Video", "Audio", "Subtitles" }; }
        @foreach (var groupType in trackGroups)
        {
            var groupTracks = Title.Tracks.Where(t => t.Type == groupType).ToList();
            if (groupTracks.Count > 0)
            {
                <h3 class="mt-4 mb-2">@groupType Tracks</h3>
                <div class="table-responsive">
                    <table class="table striped-grid mb-0">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 5rem;">Index</th>
                                <th scope="col">Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var track in groupTracks)
                            {
                                <tr>
                                    <td>@track.Index</td>
                                    <td>@track.GetDesciption()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </div>
}