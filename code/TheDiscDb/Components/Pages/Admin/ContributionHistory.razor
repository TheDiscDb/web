@page "/admin/contribution/{contributionId}/history"
@using TheDiscDb.Client.Controls

@rendermode InteractiveServer

<PageTitle>Admin - Contribution History</PageTitle>

<TheDiscDb.Client.Controls.Breadcrumb Items="[GetRootAdminLink(), GetAdminContributionLink(this.Contribution)]" PrimaryText="History" />

<h1>Contribution History</h1>

@if (this.Contribution != null)
{
    <h2>@this.Contribution.Title (@this.Contribution.Year) - @this.Contribution.ReleaseTitle</h2>

    <section class="info-card">
        <h3>Send Message</h3>
        <div class="mb-3">
            <textarea class="form-control" rows="4" placeholder="Type a message (markdown supported)..." @bind="newMessage"></textarea>
        </div>
        <SfButton OnClick="SendMessage" CssClass="e-primary" Disabled="@string.IsNullOrWhiteSpace(newMessage)">
            Send Admin Message
        </SfButton>
        @if (!string.IsNullOrEmpty(sendError))
        {
            <div class="alert alert-danger mt-2">@sendError</div>
        }
    </section>

    <section class="info-card">
        <h3>History</h3>
        @if (HistoryItems != null && HistoryItems.Any())
        {
            <QuickGrid Items="HistoryItems.AsQueryable()" Class="striped-grid">
                <TemplateColumn Title="Type" Sortable="true" SortBy="GridSort<Web.Data.ContributionHistory>.ByAscending(h => h.Type)">
                    <span class="badge @GetBadgeClass(context.Type)">@context.Type</span>
                </TemplateColumn>
                <TemplateColumn Title="Date" Sortable="true" SortBy="GridSort<Web.Data.ContributionHistory>.ByDescending(h => h.TimeStamp)">
                    @context.TimeStamp.ToString("yyyy-MM-dd HH:mm")
                </TemplateColumn>
                <PropertyColumn Property="@(h => GetUserName(h.UserId))" Title="User" />
                <TemplateColumn Title="Description">
                    <TheDiscDb.Components.Controls.MarkdownContent Content="@context.Description" />
                </TemplateColumn>
            </QuickGrid>
        }
        else
        {
            <p class="text-muted">No history entries yet.</p>
        }
    </section>
}
else
{
    <p>Contribution not found.</p>
}
