@page "/{type}/{slug}"

@if (Item == null)
{
    <div>Item not found</div>
}
else
{
    <PageTitle>@Item.Title - TheDiscDb</PageTitle>
    <HeadContent>
        @{ var metaDesc = $"{Item.FullTitle} — {TruncateForDescription(Item.Plot, 110)} Browse {Item.Releases.Count} release(s) with full disc structures and MakeMKV playlists on TheDiscDb."; }
        <meta name="description" content="@metaDesc" />
        <link rel="canonical" href="@BuildCanonicalLink(GetMediaItemLink(Item))" />
        <meta property="og:title" content="@Item.Title - TheDiscDb" />
        <meta property="og:description" content="@metaDesc" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="@BuildCanonicalLink(GetMediaItemLink(Item))" />
        <meta property="og:image" content="https://thediscdb.com/images/@(Item.ImageUrl)?width=600&amp;height=900" />
        <meta property="og:image:width" content="600" />
        <meta property="og:image:height" content="900" />
        <meta property="og:site_name" content="TheDiscDb" />
    </HeadContent>
    <div class="vstack">
        <TheDiscDb.Client.Controls.Breadcrumb Items="[GetRootLink(this.Item)]" PrimaryText="@Item.Title" />
        <div class="d-flex flex-column flex-md-row gap-3 align-items-start">
            <img src="/images/@Item.ImageUrl?width=345&height=518" alt="@Item.FullTitle" class="mediaItemDetailCover img-fluid" style="max-width: 345px;" />
            <div class="vstack">
                <h1>@Item.FullTitle</h1>
                @if (HasAnyFacts)
                {
                    <div class="facts flex-wrap">
                        @if (!string.IsNullOrWhiteSpace(Item.ContentRating))
                        {
                            <span class="certification">@Item.ContentRating</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Item.Genres))
                        {
                            <span class="genres"><GroupList Item="@Item" ListText="@Item.Genres" Role="Genre" /></span>
                        }
                        @if (!string.IsNullOrWhiteSpace(Item.Runtime))
                        {
                            <span class="runtime">@Item.Runtime</span>
                        }
                    </div>
                }
                <div>
                    @if (!string.IsNullOrWhiteSpace(Item.Tagline))
                    {
                        <h3 class="tagline" dir="auto">@Item.Tagline</h3>
                    }
                    <h3 dir="auto">Overview</h3>
                    <div class="overview" dir="auto">
                        <p>@Item.Plot</p>
                    </div>
                </div>
                @if (HasAnyPeople)
                {
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        @if (!string.IsNullOrWhiteSpace(Item.Directors))
                        {
                            <div class="vstack">
                                <p class="people-role">Directors</p>
                                <div class="people"><GroupList Item="@Item" ListText="@Item.Directors" Role="Director" /></div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Item.Stars))
                        {
                            <div class="vstack">
                                <p class="people-role">Stars</p>
                                <div class="people"><GroupList Item="@Item" ListText="@Item.Stars" Role="Actor" /></div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Item.Writers))
                        {
                            <div class="vstack">
                                <p class="people-role">Writers</p>
                                <div class="people"><GroupList Item="@Item" ListText="@Item.Writers" Role="Writer" /></div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @if (CustomGroups.Count > 0)
    {
        <section class="categories-section">
            <h3>Categories</h3>
            <div class="category-list">
                @foreach (var group in CustomGroups)
                {
                    <a href="/g/@group.Slug" class="category-chip">@group.Name</a>
                }
            </div>
        </section>
    }

    <ReleaseList Item="@Item" Releases="Releases" />
}