@page "/contribute/engram/{releaseId}"

<PageTitle>Engram Submission - TheDiscDb</PageTitle>

@if (Submissions == null || !Submissions.Any())
{
    <h1>Engram Submissions</h1>
    <p>No submissions found for this release.</p>
}
else
{
    <h1>Engram Submissions</h1>
    <p>@Submissions.Count submission(s) for release <code>@ReleaseId</code></p>

    @foreach (var submission in Submissions)
    {
        <section class="engram-submission">
            <h2>@submission.VolumeLabel</h2>
            <div class="engram-details">
                <dl>
                    <dt>Content Hash</dt>
                    <dd><code>@submission.ContentHash</code></dd>

                    <dt>Content Type</dt>
                    <dd>@submission.ContentType</dd>

                    @if (submission.DiscNumber.HasValue)
                    {
                        <dt>Disc Number</dt>
                        <dd>@submission.DiscNumber</dd>
                    }

                    @if (!string.IsNullOrEmpty(submission.DetectedTitle))
                    {
                        <dt>Detected Title</dt>
                        <dd>@submission.DetectedTitle</dd>
                    }

                    @if (submission.TmdbId.HasValue)
                    {
                        <dt>TMDB ID</dt>
                        <dd><a href="https://www.themoviedb.org/movie/@submission.TmdbId" target="_blank">@submission.TmdbId</a></dd>
                    }

                    @if (submission.DetectedSeason.HasValue)
                    {
                        <dt>Detected Season</dt>
                        <dd>@submission.DetectedSeason</dd>
                    }

                    @if (!string.IsNullOrEmpty(submission.ClassificationSource))
                    {
                        <dt>Classification</dt>
                        <dd>@submission.ClassificationSource (@(submission.ClassificationConfidence?.ToString("P0") ?? "N/A"))</dd>
                    }

                    @if (!string.IsNullOrEmpty(submission.Upc))
                    {
                        <dt>UPC</dt>
                        <dd>@submission.Upc</dd>
                    }

                    <dt>Engram Version</dt>
                    <dd>@submission.EngramVersion</dd>

                    <dt>Export Version</dt>
                    <dd>@submission.ExportVersion</dd>

                    <dt>Contribution Tier</dt>
                    <dd>@submission.ContributionTier</dd>

                    <dt>Received</dt>
                    <dd>@submission.ReceivedAt.ToString("g")</dd>

                    @if (submission.UpdatedAt.HasValue)
                    {
                        <dt>Updated</dt>
                        <dd>@submission.UpdatedAt.Value.ToString("g")</dd>
                    }
                </dl>
            </div>

            @if (submission.Titles.Any())
            {
                <h3>Titles (@submission.Titles.Count)</h3>
                <table class="engram-titles-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Source</th>
                            <th>Type</th>
                            <th>Duration</th>
                            <th>Size</th>
                            <th>Chapters</th>
                            <th>Segments</th>
                            <th>Season</th>
                            <th>Episode</th>
                            <th>Edition</th>
                            <th>Match</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var title in submission.Titles.OrderBy(t => t.TitleIndex))
                        {
                            <tr>
                                <td>@title.TitleIndex</td>
                                <td>@title.SourceFilename</td>
                                <td>@title.TitleType</td>
                                <td>@FormatDuration(title.DurationSeconds)</td>
                                <td>@FormatSize(title.SizeBytes)</td>
                                <td>@title.ChapterCount</td>
                                <td>@title.SegmentCount (@title.SegmentMap)</td>
                                <td>@title.Season</td>
                                <td>@title.Episode</td>
                                <td>@title.Edition</td>
                                <td>
                                    @if (title.MatchConfidence.HasValue)
                                    {
                                        <span title="@title.MatchSource">@title.MatchConfidence.Value.ToString("P0")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    }
}
