@page "/contribute/engram/{releaseId}"
@rendermode InteractiveServer

<PageTitle>Continue Engram Submission - TheDiscDb</PageTitle>

@if (string.IsNullOrEmpty(ReleaseId) || Submissions == null || !Submissions.Any())
{
    <div class="contribute-layout engram-bridge">
        <div class="page-header">
            <h1>No Engram submission found</h1>
            <p class="page-header__sub">We couldn't find any Engram disc data for that release id.</p>
        </div>
        <a href="/contribute" class="btn btn-primary">Back to Contribute</a>
    </div>
}
else if (ExistingContributionEncodedId != null)
{
    <div class="contribute-layout engram-bridge">
        <div class="page-header">
            <h1>You already started this contribution</h1>
            <p class="page-header__sub">Pick up where you left off.</p>
        </div>
        <a href="/contribution/engram/@ExistingContributionEncodedId" class="btn btn-primary">Continue Editing Contribution</a>
    </div>
}
else
{
    <div class="contribute-layout engram-bridge">
        <section class="contribute-hero compact">
            <h1>Finish your Engram submission</h1>
            <p>
                Engram captured @Submissions.Count disc(s) for this release. Confirm a few release details
                and we'll create a contribution you can keep working on — disc identification, review, and
                final submission all happen in the standard contribution flow.
            </p>
        </section>

        @if (TmdbLookupFailed)
        {
            <div class="alert alert-warning">
                We couldn't reach TMDB to look up this title automatically. You'll be able to fix the
                title and cover from the contribution page after you continue.
            </div>
        }

        <section class="info-card engram-summary-card">
            <div class="engram-summary">
                @if (!string.IsNullOrEmpty(TmdbPosterUrl))
                {
                    <img class="cover" src="@TmdbPosterUrl" alt="Cover for @ResolvedTitle()" width="160" height="240" />
                }
                else if (!string.IsNullOrEmpty(Submissions.First().FrontImageUrl))
                {
                    <div class="cover cover-placeholder">Cover from disc upload will be used</div>
                }
                else
                {
                    <div class="cover cover-placeholder">No cover available</div>
                }
                <dl>
                    <dt>Title</dt>
                    <dd>@ResolvedTitle() @(string.IsNullOrEmpty(ResolvedYear()) ? null : $"({ResolvedYear()})")</dd>

                    @if (Submissions.First().TmdbId.HasValue)
                    {
                        <dt>TMDB id</dt>
                        <dd>@Submissions.First().TmdbId</dd>
                    }

                    @if (!string.IsNullOrEmpty(Submissions.First().Upc))
                    {
                        <dt>UPC</dt>
                        <dd>@Submissions.First().Upc</dd>
                    }

                    <dt>Engram release id</dt>
                    <dd><code>@ReleaseId</code></dd>
                </dl>
            </div>
        </section>

        <section class="info-card engram-discs-card">
            <h2>Discs Engram captured</h2>
            <table class="engram-titles-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Volume Label</th>
                        <th>Format</th>
                        <th>Titles</th>
                        <th>Scan Log</th>
                        <th>Cover</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int discNum = 1; }
                    @foreach (var submission in Submissions)
                    {
                        <tr>
                            <td>@(submission.DiscNumber ?? discNum)</td>
                            <td>@submission.VolumeLabel</td>
                            <td>@MapContentTypeToFormat(submission.ContentType)</td>
                            <td>@submission.Titles.Count</td>
                            <td>@(string.IsNullOrEmpty(submission.ScanLogPath) ? "—" : "✓")</td>
                            <td>@(string.IsNullOrEmpty(submission.FrontImageUrl) ? "—" : "✓")</td>
                        </tr>
                        discNum++;
                    }
                </tbody>
            </table>
        </section>

        <section class="info-card engram-form-card">
            <h2>A few details Engram doesn't have</h2>
            <p class="form-hint">
                These fields are required for every contribution. You can edit anything here later
                from the contribution's release details page.
            </p>

            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="alert alert-danger">@ErrorMessage</div>
            }

            <EditForm Model="request" OnValidSubmit="CreateContributionFromEngram" FormName="createContribution">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-grid">
                    <div class="form-group">
                        <label>Media type</label>
                        <InputRadioGroup @bind-Value="request.MediaType">
                            <label class="radio-option">
                                <InputRadio Value="@("movie")" /> Movie
                            </label>
                            <label class="radio-option">
                                <InputRadio Value="@("series")" /> Series
                            </label>
                        </InputRadioGroup>
                    </div>

                    <div class="form-group">
                        <TheDiscDb.Client.Controls.ReleaseDateInput @ref="releaseDateInput" @bind-Value="request.ReleaseDate" Required="true" />
                    </div>

                    <div class="form-group">
                        <label for="asin">ASIN *</label>
                        <InputText id="asin" @bind-Value="request.Asin" class="form-control" placeholder="10 characters" />
                    </div>

                    <div class="form-group">
                        <label for="upc">UPC *</label>
                        <InputText id="upc" @bind-Value="request.Upc" class="form-control" placeholder="12-13 digits" />
                    </div>

                    <div class="form-group">
                        <label for="locale">Locale *</label>
                        <InputText id="locale" @bind-Value="request.Locale" class="form-control" />
                    </div>

                    <div class="form-group">
                        <label for="regionCode">Region Code *</label>
                        <InputText id="regionCode" @bind-Value="request.RegionCode" class="form-control" />
                    </div>
                </div>

                <div class="cta-row split">
                    <a class="btn btn-secondary" href="/contribute">Cancel</a>
                    <button type="submit" class="btn btn-primary" disabled="@IsCreating">
                        @if (IsCreating)
                        {
                            <span>Creating contribution…</span>
                        }
                        else
                        {
                            <span>Start Contribution</span>
                        }
                    </button>
                </div>
            </EditForm>
        </section>
    </div>
}
