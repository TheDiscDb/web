@page "/contribute/engram/{releaseId}"
@rendermode InteractiveServer

<PageTitle>Engram Submission - TheDiscDb</PageTitle>

@if (Submissions == null || !Submissions.Any())
{
    <div class="page-header">
        <h1>Engram Submissions</h1>
    </div>
    <p>No submissions found for this release.</p>
}
else if (ExistingContributionId != null)
{
    <div class="page-header">
        <h1>Engram Submissions</h1>
        <div class="page-header__sub">This release has already been converted to a contribution.</div>
    </div>
    <a href="/contribution/@ExistingContributionEncodedId" class="btn btn-primary">Continue Editing Contribution</a>
}
else
{
    <div class="page-header">
        <h1>Create Contribution from Engram</h1>
        <div class="page-header__sub">@Submissions.Count disc(s) for release <code>@ReleaseId</code></div>
    </div>

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }

    <EditForm Model="request" OnValidSubmit="CreateContributionFromEngram" FormName="createContribution">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <h2>Release Information</h2>
        <div class="form-grid">
            <div class="form-group">
                <label for="title">Title</label>
                <InputText id="title" @bind-Value="request.Title" class="form-control" />
            </div>
            <div class="form-group">
                <label for="year">Year</label>
                <InputText id="year" @bind-Value="request.Year" class="form-control" />
            </div>
            <div class="form-group">
                <label for="mediaType">Media Type</label>
                <InputSelect id="mediaType" @bind-Value="request.MediaType" class="form-control">
                    <option value="movie">Movie</option>
                    <option value="series">Series</option>
                </InputSelect>
            </div>
            <div class="form-group">
                <label for="externalId">External ID (TMDB)</label>
                <InputText id="externalId" @bind-Value="request.ExternalId" class="form-control" />
            </div>
        </div>

        <h2>Release Details</h2>
        <div class="form-grid">
            <div class="form-group">
                <label for="releaseTitle">Release Title *</label>
                <InputText id="releaseTitle" @bind-Value="request.ReleaseTitle" class="form-control" />
            </div>
            <div class="form-group">
                <label for="releaseSlug">Release Slug *</label>
                <InputText id="releaseSlug" @bind-Value="request.ReleaseSlug" class="form-control" />
            </div>
            <div class="form-group">
                <label for="releaseDate">Release Date *</label>
                <InputDate id="releaseDate" @bind-Value="request.ReleaseDate" class="form-control" />
            </div>
            <div class="form-group">
                <label for="asin">ASIN *</label>
                <InputText id="asin" @bind-Value="request.Asin" class="form-control" placeholder="10 characters" />
            </div>
            <div class="form-group">
                <label for="upc">UPC *</label>
                <InputText id="upc" @bind-Value="request.Upc" class="form-control" placeholder="12-13 digits" />
            </div>
            <div class="form-group">
                <label for="regionCode">Region Code *</label>
                <InputText id="regionCode" @bind-Value="request.RegionCode" class="form-control" />
            </div>
            <div class="form-group">
                <label for="locale">Locale *</label>
                <InputText id="locale" @bind-Value="request.Locale" class="form-control" />
            </div>
        </div>

        @if (!string.IsNullOrEmpty(request.FrontImageUrl))
        {
            <p><strong>Front image:</strong> Will be copied from engram submission</p>
        }
        else
        {
            <p class="text-warning">No front image available from engram — you can upload one after the contribution is created.</p>
        }

        <h2>Discs (@Submissions.Count)</h2>
        <table class="engram-titles-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Volume Label</th>
                    <th>Format</th>
                    <th>Content Hash</th>
                    <th>Titles</th>
                    <th>Scan Log</th>
                </tr>
            </thead>
            <tbody>
                @{ int discNum = 1; }
                @foreach (var submission in Submissions)
                {
                    <tr>
                        <td>@(submission.DiscNumber ?? discNum)</td>
                        <td>@submission.VolumeLabel</td>
                        <td>@MapContentTypeToFormat(submission.ContentType)</td>
                        <td><code>@submission.ContentHash[..Math.Min(12, submission.ContentHash.Length)]…</code></td>
                        <td>@submission.Titles.Count</td>
                        <td>@(string.IsNullOrEmpty(submission.ScanLogPath) ? "No" : "Yes")</td>
                    </tr>
                    discNum++;
                }
            </tbody>
        </table>

        <div class="form-actions" style="margin-top: 1rem;">
            <button type="submit" class="btn btn-primary" disabled="@IsCreating">
                @if (IsCreating)
                {
                    <span>Creating…</span>
                }
                else
                {
                    <span>Create Contribution</span>
                }
            </button>
        </div>
    </EditForm>
}
