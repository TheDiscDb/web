@page "/contribution/boxset/{BoxsetId}/review"

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="Review Boxset" Items='[("Home", "/"), ("Contribute", "/contribute"), ("My Contributions", "/contribute/my")]' />

<div class="contribute-layout">
    @if (isLoading)
    {
        <section class="info-card">
            <p>Loading...</p>
        </section>
    }
    else if (Boxset == null)
    {
        <section class="info-card">
            <div class="alert alert-danger">Boxset not found.</div>
        </section>
    }
    else
    {
        <section class="contribute-hero compact">
            <h1>Review: @Boxset.Title</h1>
            <p>All validations must pass before you can submit this boxset for review.</p>
        </section>

        <section class="info-card">
            <h2>Validation Results</h2>
            <ul class="list-group mb-3">
                @foreach (var (name, result) in Results)
                {
                    <li class="list-group-item d-flex align-items-center">
                        @if (result.IsSuccess)
                        {
                            <span class="text-success me-2">&#10003;</span>
                        }
                        else
                        {
                            <span class="text-danger me-2">&#10007;</span>
                        }
                        <div>
                            <strong>@name</strong>
                            @if (!result.IsSuccess)
                            {
                                <div class="text-danger small">@string.Join("; ", result.Errors.Select(e => e.Message))</div>
                            }
                        </div>
                    </li>
                }
            </ul>

            <h3>Boxset Discs</h3>
            <ul class="list-group mb-3">
                @foreach (var member in Boxset.Members.OrderBy(m => m.SortOrder))
                {
                    <li class="list-group-item">
                        <strong>Disc @(member.SortOrder + 1): @member.Disc.Name</strong> (@member.Disc.Format)
                        <span class="text-muted ms-2">from: @member.Disc.UserContribution.Title</span>
                        <span class="badge bg-secondary ms-1">@member.Disc.UserContribution.Status</span>
                    </li>
                }
            </ul>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="d-flex gap-2">
                <button class="btn btn-primary" disabled="@(!PassedValidation || isSubmitting)" @onclick="HandleSubmit">
                    @if (isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    Submit Boxset for Review
                </button>
                <a class="btn btn-secondary" href="/contribution/boxset/@BoxsetId">Back to Boxset</a>
            </div>
        </section>
    }
</div>
