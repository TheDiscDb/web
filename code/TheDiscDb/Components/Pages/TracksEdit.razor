@page "/{type}/{slug}/releases/{releaseSlug}/discs/{slugOrIndex}/{file}/{extension}/tracks/edit"
@page "/{type}/{slug}/releases/{releaseSlug}/discs/{slugOrIndex}/{file}/tracks/edit"
@page "/{type}/{slug}/discs/{slugOrIndex}/{file}/tracks/edit"
@page "/{type}/{slug}/discs/{slugOrIndex}/{file}/{extension}/tracks/edit"

@rendermode InteractiveServer

<PageTitle>Edit Tracks - TheDiscDb</PageTitle>

@if (Item == null || Release == null || Disc == null || Title == null)
{
    <div class="alert alert-warning">Tracks not found.</div>
}
else if (string.IsNullOrEmpty(Disc.Slug))
{
    <TheDiscDb.Client.Controls.Breadcrumb Items="@GetBreadcrumbs()" PrimaryText="Edit Tracks" />
    <div class="alert alert-info">Track editing isn't available for this disc.</div>
}
else
{
    <TheDiscDb.Client.Controls.Breadcrumb Items="@GetBreadcrumbs()" PrimaryText="Edit Tracks" />

    @if (!string.IsNullOrEmpty(submitMessage))
    {
        <div class="alert @(submitSuccess ? "alert-success" : "alert-danger")">@submitMessage</div>
    }

    @if (!isReviewing)
    {
        <h1>Suggest Track Edits</h1>
        <p class="text-muted">
            Edit the track names below. Only the name can be changed — all other fields come
            from the disc file metadata. Your changes will be reviewed before being applied.
        </p>

        <section class="info-grid single-column">
            @{ var trackGroups = new[] { "Video", "Audio", "Subtitles" }; }
            @foreach (var groupType in trackGroups)
            {
                var groupRows = rows.Where(r => r.Track.Type == groupType).ToList();
                if (groupRows.Count > 0)
                {
                    <h3 class="mt-4 mb-2">@groupType Tracks</h3>
                    <div class="table-responsive">
                        <table class="table striped-grid mb-0">
                            <thead>
                                <tr>
                                    <th scope="col" style="width: 5rem;">Index</th>
                                    <th scope="col">Details</th>
                                    <th scope="col">Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in groupRows)
                                {
                                    <tr>
                                        <td>@row.Track.Index</td>
                                        <td class="text-muted">@GetMetadata(row.Track)</td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm"
                                                   @bind="row.EditName" placeholder="Track name" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }

            <div class="d-flex gap-2 mt-4">
                <button type="button" class="btn btn-primary" @onclick="ShowReview" disabled="@(!HasChanges())">
                    Review Suggested Changes
                </button>
                <a href="@GetTitleUrl()" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </section>
    }
    else
    {
        <h1>Review Your Track Changes</h1>
        <p class="text-muted">These changes will be submitted for review by an admin.</p>

        <section class="info-grid single-column">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Track</th>
                        <th>Current Name</th>
                        <th>Proposed Name</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var diff in pendingDiffs)
                    {
                        <tr class="table-warning">
                            <td><strong>@diff.Type @diff.Index</strong> <span class="text-muted">@diff.Metadata</span></td>
                            <td class="text-muted">@(string.IsNullOrEmpty(diff.CurrentName) ? "—" : diff.CurrentName)</td>
                            <td><strong>@(string.IsNullOrEmpty(diff.ProposedName) ? "—" : diff.ProposedName)</strong></td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (pendingDiffs.Count == 0)
            {
                <div class="alert alert-info">No changes detected.</div>
            }

            @if (pendingDiffs.Count > 0)
            {
                <div class="mb-3">
                    <label>Summary <span class="text-muted">(optional — briefly describe your changes)</span></label>
                    <input type="text" class="form-control" @bind="summary" />
                </div>
            }

            <div class="d-flex gap-2">
                @if (pendingDiffs.Count > 0 && !submitSuccess)
                {
                    <button type="button" class="btn btn-primary" disabled="@isSubmitting" @onclick="HandleSubmit">
                        @(isSubmitting ? "Submitting…" : "Submit Changes")
                    </button>
                }
                @if (!submitSuccess)
                {
                    <button type="button" class="btn btn-outline-secondary" @onclick="BackToEdit">← Back to Edit</button>
                }
            </div>
        </section>
    }
}
