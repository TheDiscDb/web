@page "/g/{slug}"

@if (!groupExists)
{
    <PageTitle>Not Found - TheDiscDb</PageTitle>
    <div>Category not found</div>
}
else
{
    <PageTitle>Items related to '@(groupName ?? Slug)' - TheDiscDb</PageTitle>
    <HeadContent>
        <meta name="description" content="Browse all movies, TV series, and boxsets related to '@(groupName ?? Slug)' on TheDiscDb. Find disc details, release information, and more." />
        <link rel="canonical" href="https://thediscdb.com/g/@Uri.EscapeDataString(Slug ?? "")" />
    </HeadContent>

    <div class="page-header">
        <h1>Items related to <span class="page-header__accent">'@(groupName ?? Slug)'</span></h1>
    </div>
    <TheDiscDb.Client.Pages.ItemsByCategory Slug="@Slug" @rendermode="new InteractiveWebAssemblyRenderMode(prerender: true)" />
}
