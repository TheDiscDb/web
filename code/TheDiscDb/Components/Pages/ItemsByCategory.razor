@page "/g/{slug}"

@if (!groupExists)
{
    <PageTitle>Not Found - TheDiscDb</PageTitle>
    <div>Category not found</div>
}
else
{
    <PageTitle>Items related to '@(groupName ?? Slug)' - TheDiscDb</PageTitle>
    <HeadContent>
        <meta name="description" content="Browse all movies, TV series, and boxsets related to '@(groupName ?? Slug)' on TheDiscDb. Find disc details, release information, and more." />
        <link rel="canonical" href="https://thediscdb.com/g/@Uri.EscapeDataString(Slug ?? "")" />
    </HeadContent>

    <div class="page-header">
        <h1>Items related to <span class="page-header__accent">'@(groupName ?? Slug)'</span></h1>
    </div>

    @if (isCrawler)
    {
        @if (initialItems.Count == 0)
        {
            <p>No items have been added for this category yet.</p>
        }
        else
        {
            <div class="media-item-list">
                @foreach (var item in initialItems)
                {
                    <a href="@item.ItemDetailUrl()" class="media-item-card" title="@item.Title">
                        <MediaImage Url="@item.ImageUrl" Width="156" Height="231" Title="@item.Title" />
                        <span class="media-item-label">@item.Title (@item.Year)</span>
                    </a>
                }
            </div>

            @if (hasMoreItems)
            {
                <p class="text-muted mt-3">
                    Showing the first @initialItems.Count items. Use
                    <a href="/search?query=@Uri.EscapeDataString(groupName ?? Slug ?? "")">search</a>
                    to find additional matches.
                </p>
            }
        }
    }
    else
    {
        <TheDiscDb.Client.Pages.ItemsByCategory Slug="@Slug" @rendermode="new InteractiveWebAssemblyRenderMode(prerender: true)" />
    }
}
