@page "/boxset/{slug}"

@if (Item == null || Release == null)
{
    <PageTitle>Not Found - TheDiscDb</PageTitle>
    <div>Boxset not found</div>
}
else
{
    <PageTitle>@Item.Title - TheDiscDb</PageTitle>
    <HeadContent>
        @{ var boxsetMetaDesc = $"{Item.Title} boxset — {Release.Discs.Count} disc(s) released {Release.ReleaseDate.ToString("d")}. Full disc structures, MakeMKV playlists, and title listings on TheDiscDb."; }
        <meta name="description" content="@boxsetMetaDesc" />
        <link rel="canonical" href="@BuildCanonicalLink(GetBoxsetLink(Item))" />
        <meta property="og:title" content="@Item.Title - TheDiscDb" />
        <meta property="og:description" content="@boxsetMetaDesc" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="@BuildCanonicalLink(GetBoxsetLink(Item))" />
        <meta property="og:image" content="https://thediscdb.com/images/@(Item.ImageUrl)?width=600&amp;height=900" />
        <meta property="og:image:width" content="600" />
        <meta property="og:image:height" content="900" />
        @if (!string.IsNullOrEmpty(Release?.BackImageUrl))
        {
            <meta property="og:image" content="https://thediscdb.com/images/@(Release.BackImageUrl)?width=600&amp;height=900" />
            <meta property="og:image:width" content="600" />
            <meta property="og:image:height" content="900" />
        }
        <meta property="og:site_name" content="TheDiscDb" />
    </HeadContent>
    <div class="vstack">
        <TheDiscDb.Client.Controls.Breadcrumb Items="[GetBoxsetRootLink()]" PrimaryText="@Item.Title" />
        <div class="d-flex flex-column flex-md-row gap-3 align-items-start">
            <div class="cover-images">
                <img src="/images/@Item.ImageUrl?width=345&height=518" alt="@Item.Title" class="mediaItemDetailCover img-fluid" style="max-width: 345px;" />
                @if (!string.IsNullOrEmpty(Release?.BackImageUrl))
                {
                    <a href="/images/@(Release.BackImageUrl)?width=800&height=1200" target="_blank" class="back-cover-link">
                        <img src="/images/@(Release.BackImageUrl)?width=120&height=170" alt="Back cover" />
                    </a>
                }
            </div>
            <div class="vstack">
                <h1>@Item.Title</h1>
                <h3>@Release?.Title</h3>
                <div class="hstack gap-3">
                    <label>Release Date:</label>
                    @Release?.ReleaseDate.ToString("d")
                </div>
                <AmazonAssociatesButton Asin="@Release?.Asin" />
                @if (Release?.Discs != null && Release.Discs.Count > 0)
                {
                    <h3 class="disc-list-heading">Discs</h3>
                    <ul class="disc-list">
                        @foreach (var disc in Release.Discs)
                        {
                            var features = NavigationExtensions.GetDiscFeatures(disc).ToList();
                            <li class="disc-list-item">
                                <a class="disc-list-header" href="@disc.DiscDetailUrl(Release, this.Item)">
                                    <span class="disc-list-name">
                                        <svg class="disc-list-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                            <circle cx="12" cy="12" r="10" />
                                            <circle cx="12" cy="12" r="3" />
                                        </svg>
                                        <span>@disc.GetFullName()</span>
                                    </span>
                                    @if (features.Count > 0)
                                    {
                                        <span class="disc-list-count">@features.Count @(features.Count == 1 ? "title" : "titles")</span>
                                    }
                                </a>
                                @if (features.Count > 0)
                                {
                                    <ul class="disc-feature-list">
                                        @foreach (var feature in features)
                                        {
                                            <li class="disc-feature-item">
                                                <span class="feature">@feature.Description</span>
                                                @if (feature.HasChapters)
                                                {
                                                    <span class="chapter-badge" title="Has chapter names" aria-label="Has chapter names">
                                                        <SfIcon Name="IconName.ListOrdered" />
                                                    </span>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
}