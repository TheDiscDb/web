@page "/boxsets"

<PageTitle>All Boxsets - TheDiscDb</PageTitle>
<HeadContent>
    <meta name="description" content="Browse all boxsets on TheDiscDb. Boxsets contain multiple titles and discs — find Blu-ray, 4K UHD, and DVD disc structures, MakeMKV playlists, and release details." />
    <link rel="canonical" href="https://thediscdb.com/boxsets" />
</HeadContent>

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="Boxsets" Items='[("Home", "/")]' />

<div class="page-header">
    <h1>All Boxsets</h1>
    <div class="page-header__sub">Multi-title collections</div>
</div>

@if (isCrawler)
{
    @if (ssrItems.Count == 0)
    {
        <p>No boxsets have been added yet.</p>
    }
    else
    {
        <div class="media-item-list">
            @foreach (var item in ssrItems)
            {
                <a href="@item.ItemDetailUrl()" class="media-item-card" title="@item.Title">
                    <MediaImage Url="@item.ImageUrl" Width="156" Height="231" Title="@item.Title" />
                    <span class="media-item-label">@item.Title</span>
                </a>
            }
        </div>
    }
}
else
{
    <TheDiscDb.Client.Pages.Boxsets @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
}
