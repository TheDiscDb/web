@page "/"
@page "/movies"

<PageTitle>All Movies - TheDiscDb</PageTitle>
<HeadContent>
    <meta name="description" content="Browse the full list of movies on TheDiscDb. Find Blu-ray, 4K UHD, and DVD disc details, MakeMKV playlists, and release information for every movie in our database." />
    <link rel="canonical" href="https://thediscdb.com/movies" />
</HeadContent>

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="Movies" Items='[("Home", "/")]' />

<div class="page-header">
    <h1>All Movies</h1>
    <div class="page-header__sub">Blu-ray, 4K UHD &amp; DVD releases</div>
</div>

@if (isCrawler)
{
    @if (ssrItems.Count == 0)
    {
        <p>No movies have been added yet.</p>
    }
    else
    {
        <div class="media-item-list">
            @foreach (var item in ssrItems)
            {
                <a href="@item.ItemDetailUrl()" class="media-item-card" title="@item.Title">
                    <MediaImage Url="@item.ImageUrl" Width="156" Height="231" Title="@item.Title" />
                    <span class="media-item-label">@item.Title (@item.Year)</span>
                </a>
            }
        </div>
    }
}
else
{
    <TheDiscDb.Client.Pages.Movies @rendermode="new InteractiveWebAssemblyRenderMode(prerender: false)" />
}
