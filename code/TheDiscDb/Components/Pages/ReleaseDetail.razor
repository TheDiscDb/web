@page "/{type}/{slug}/releases/{releaseSlug}"

@if (Item == null || Release == null)
{
    <div>Item or release not found</div>
}
else
{
    <PageTitle>@Item.Title - @Release.Title - TheDiscDb</PageTitle>
    <HeadContent>
        @{ var releaseMetaDesc = $"{Release.Title} release of {Item.Title} ({string.Format("{0:d}", Release.ReleaseDate)}) — {Release.Discs.Count} disc(s) with full title listings, MakeMKV playlists, and file structures on TheDiscDb."; }
        <meta name="description" content="@releaseMetaDesc" />
        <link rel="canonical" href="@BuildCanonicalLink(GetReleaseLink(Item, Release))" />
        <meta property="og:title" content="@Item.Title - @Release.Title - TheDiscDb" />
        <meta property="og:description" content="@releaseMetaDesc" />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="@BuildCanonicalLink(GetReleaseLink(Item, Release))" />
        <meta property="og:image" content="https://thediscdb.com/images/@(Release.ImageUrl)?width=600&amp;height=900" />
        <meta property="og:image:width" content="600" />
        <meta property="og:image:height" content="900" />
        @if (!string.IsNullOrEmpty(Release.BackImageUrl))
        {
            <meta property="og:image" content="https://thediscdb.com/images/@(Release.BackImageUrl)?width=600&amp;height=900" />
            <meta property="og:image:width" content="600" />
            <meta property="og:image:height" content="900" />
        }
        <meta property="og:site_name" content="TheDiscDb" />
    </HeadContent>
    <div class="vstack">
        <TheDiscDb.Client.Controls.Breadcrumb Items="[GetRootLink(this.Item), GetMediaItemLink(this.Item)]" PrimaryText="@Release.Title" />
        <div class="d-flex flex-column flex-md-row gap-3 align-items-start">
            <div class="cover-images">
                <MediaImage Url="@Release?.ImageUrl" Width="413" Height="525" Title="@Release?.FullTitle" CssClass="mediaItemDetailCover img-fluid" Style="max-width: 413px;" />
                @if (!string.IsNullOrEmpty(Release?.BackImageUrl))
                {
                    <a href="/images/@(Release.BackImageUrl)?width=800&height=1200" target="_blank" class="back-cover-link">
                        <MediaImage Url="@Release.BackImageUrl" Width="120" Height="170" Title="Back cover" CssClass="back-cover-thumb" />
                    </a>
                }
            </div>
            <div class="release-info-column">
                <div>
                    <h1>@Item.FullTitle</h1>
                    <h2>@Release?.FullTitle</h2>
                    <div>Released @string.Format("{0:d}", @Release?.ReleaseDate)</div>
                    @if (!string.IsNullOrEmpty(Release?.Upc))
                    {
                        <div class="upc-line">
                            UPC: <span class="upc-link" onclick="document.getElementById('barcode-dialog').showModal()">@Release.Upc</span>
                        </div>
                        <dialog id="barcode-dialog" class="barcode-dialog" onclick="if(event.target===this)this.close()">
                            <button class="barcode-dialog-close" onclick="document.getElementById('barcode-dialog').close()" aria-label="Close">&times;</button>
                            <div class="barcode-dialog-content">
                                <img src="/api/barcode?data=@Release.Upc&width=300&showLabel=false" alt="Barcode for @Release.Upc" />
                                <div class="barcode-dialog-upc">@Release.Upc</div>
                            </div>
                        </dialog>
                    }
                    <AmazonAssociatesButton Asin="@Release?.Asin" Width="25" />
                    <ul>
                        @if (Release?.Discs != null)
                        {
                            foreach (var disc in Release.Discs)
                            {
                                <li><a href="@disc.DiscDetailUrl(this.Release, this.Item)">@disc.FullDiscName()</a></li>
                                <ul class="facts">
                                    @foreach (var feature in NavigationExtensions.GetDiscFeatures(disc))
                                    {
                                        <li>
                                            <span class="feature">@feature.Description</span>
                                            @if (feature.HasChapters)
                                            {
                                                <span title="Has chapter names">
                                                    <SfIcon Name="IconName.ListOrdered" />
                                                </span>
                                            }
                                        </li>
                                    }
                                </ul>
                            }
                        }
                    </ul>
                </div>

                @if (Release?.Contributors != null && Release.Contributors.Any())
                {
                    <section class="contributed-by-section">
                        <h3>Contributed by</h3>
                        <div class="contributor-list">
                            @foreach (var contributor in Release.Contributors)
                            {
                                @if (string.Equals(contributor.Source, "github", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrEmpty(contributor.Name))
                                {
                                    <a href="https://github.com/@contributor.Name" target="_blank" rel="noopener noreferrer" class="contributor-chip" title="View on GitHub">
                                        <img src="https://github.com/@(contributor.Name).png?size=24" width="24" height="24" alt="@contributor.Name" class="contributor-avatar" />
                                        @contributor.Name
                                    </a>
                                }
                                else if (!string.IsNullOrEmpty(contributor.Name))
                                {
                                    <a href="/contributedBy/@Uri.EscapeDataString(contributor.Name)" class="contributor-chip" title="View contributions">
                                        @contributor.Name
                                    </a>
                                }
                            }
                        </div>
                    </section>
                }

                @if (Release?.ReleaseGroups != null && Release.ReleaseGroups.Any(rg => rg.Group != null))
                {
                    <section class="categories-section">
                        <h3>Categories</h3>
                        <div class="category-list">
                            @foreach (var rg in Release.ReleaseGroups.Where(rg => rg.Group != null))
                            {
                                <a href="/g/@rg.Group!.Slug" class="category-chip">@rg.Group.Name</a>
                            }
                        </div>
                    </section>
                }
            </div>
        </div>
    </div>
}