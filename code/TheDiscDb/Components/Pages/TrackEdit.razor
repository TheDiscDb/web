@page "/{type}/{slug}/releases/{releaseSlug}/discs/{slugOrIndex}/{file}/{extension}/tracks/{trackIndex:int}/edit"
@page "/{type}/{slug}/releases/{releaseSlug}/discs/{slugOrIndex}/{file}/tracks/{trackIndex:int}/edit"
@page "/{type}/{slug}/discs/{slugOrIndex}/{file}/tracks/{trackIndex:int}/edit"
@page "/{type}/{slug}/discs/{slugOrIndex}/{file}/{extension}/tracks/{trackIndex:int}/edit"

@rendermode InteractiveServer

<PageTitle>Edit Track - TheDiscDb</PageTitle>

@if (Item == null || Release == null || Disc == null || Title == null || Track == null)
{
    <div class="alert alert-warning">Track not found.</div>
}
else if (string.IsNullOrEmpty(Disc.Slug))
{
    <TheDiscDb.Client.Controls.Breadcrumb Items="@GetBreadcrumbs()" PrimaryText="Edit Track" />
    <div class="alert alert-info">Track editing isn't available for this disc.</div>
}
else
{
    <TheDiscDb.Client.Controls.Breadcrumb Items="@GetBreadcrumbs()" PrimaryText="Edit Track" />

    @if (!string.IsNullOrEmpty(submitMessage))
    {
        <div class="alert @(submitSuccess ? "alert-success" : "alert-danger")">@submitMessage</div>
    }

    @if (!isReviewing)
    {
        <h1>Suggest Edits for Track @Track.Index</h1>
        <p class="text-muted">
            Edit the track name below. Your changes will be reviewed before being applied.
        </p>

        <section class="info-grid single-column">
            <div class="mb-4">
                <h3>Track Details</h3>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input type="text" class="form-control" @bind="editName" placeholder="Track name" />
                    </div>
                </div>

                <p class="text-muted mt-3 mb-2">
                    The fields below come from the disc file metadata and can't be edited.
                </p>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Type</dt>
                    <dd class="col-sm-9">@(Track.Type ?? "—")</dd>

                    @if (Track.Type == "Video")
                    {
                        <dt class="col-sm-3">Resolution</dt>
                        <dd class="col-sm-9">@(Track.Resolution ?? "—")</dd>
                        <dt class="col-sm-3">Aspect Ratio</dt>
                        <dd class="col-sm-9">@(Track.AspectRatio ?? "—")</dd>
                    }
                    else if (Track.Type == "Audio" || Track.Type == "Subtitles")
                    {
                        @if (Track.Type == "Audio")
                        {
                            <dt class="col-sm-3">Audio Type</dt>
                            <dd class="col-sm-9">@(Track.AudioType ?? "—")</dd>
                        }
                        <dt class="col-sm-3">Language</dt>
                        <dd class="col-sm-9">@(Track.Language ?? "—")</dd>
                        <dt class="col-sm-3">Language Code</dt>
                        <dd class="col-sm-9">@(Track.LanguageCode ?? "—")</dd>
                        @if (!string.IsNullOrEmpty(Track.Description))
                        {
                            <dt class="col-sm-3">Description</dt>
                            <dd class="col-sm-9">@Track.Description</dd>
                        }
                    }
                </dl>
            </div>

            <div class="d-flex gap-2">
                <button type="button" class="btn btn-primary" @onclick="ShowReview" disabled="@(!HasChanges())">
                    Review Suggested Changes
                </button>
                <a href="@GetTitleUrl()" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </section>
    }
    else
    {
        <h1>Review Your Track Changes</h1>
        <p class="text-muted">These changes will be submitted for review by an admin.</p>

        <section class="info-grid single-column">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Field</th>
                        <th>Current</th>
                        <th>Proposed</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var diff in pendingDiffs)
                    {
                        <tr class="table-warning">
                            <td><strong>@diff.FieldName</strong></td>
                            <td class="text-muted">@(diff.CurrentValue ?? "—")</td>
                            <td><strong>@(diff.ProposedValue ?? "—")</strong></td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (pendingDiffs.Count == 0)
            {
                <div class="alert alert-info">No changes detected.</div>
            }

            @if (pendingDiffs.Count > 0)
            {
                <div class="mb-3">
                    <label>Summary <span class="text-muted">(optional — briefly describe your changes)</span></label>
                    <input type="text" class="form-control" @bind="summary" />
                </div>
            }

            <div class="d-flex gap-2">
                @if (pendingDiffs.Count > 0 && !submitSuccess)
                {
                    <button type="button" class="btn btn-primary" disabled="@isSubmitting" @onclick="HandleSubmit">
                        @(isSubmitting ? "Submitting…" : "Submit Changes")
                    </button>
                }
                @if (!submitSuccess)
                {
                    <button type="button" class="btn btn-outline-secondary" @onclick="BackToEdit">← Back to Edit</button>
                }
            </div>
        </section>
    }
}
