@if (Item == null || Disc == null || Release == null)
{
    <div>Loading titles...</div>
}
else
{
    <div class="d-flex align-items-center gap-2 mb-2">
        <SfSwitch TChecked="bool" ValueChange="e => AllTitlesChanged(e)" />
        <label>Show all titles</label>
    </div>

    <div class="table-responsive">
    <QuickGrid Items="FilteredTitles">
        <TemplateColumn Title="Source File" Sortable="true" SortBy="SortSourceFile">
            <a href="@TitleDetailUrl(context)">@context.SourceFile</a>
        </TemplateColumn>
        <TemplateColumn Title="Description" Sortable="true" SortBy="SortDescription">
            <div class="cell-with-copy">
                <span class="cell-with-copy-text">@context.Description</span>
                @if (!string.IsNullOrEmpty(context.Description))
                {
                    var copyState = GetDescriptionCopyState(context);
                    <button type="button"
                            class="cell-copy-button"
                            title="Copy description"
                            aria-label="Copy description"
                            disabled="@copyState.IsDisabled"
                            @onclick="() => CopyDescriptionToClipboard(context)"
                            @onclick:stopPropagation="true">
                        <i class="@copyState.IconClassName"></i>
                    </button>
                }
            </div>
        </TemplateColumn>
        <PropertyColumn Property="@(t => t.ItemType)" Title="Type" Sortable="true" />
        @if (this.Item!.Type!.Equals("series", StringComparison.OrdinalIgnoreCase))
        {
            <PropertyColumn Property="@(t => t.Season)" Sortable="true" />
            <PropertyColumn Property="@(t => t.Episode)" Sortable="true" />
        }
        <TemplateColumn Title="Segment Map" Sortable="true" SortBy="SortSegmentMap">
            <span class="segment-map-cell">@context.SegmentMap?.Replace(",", ", ")</span>
        </TemplateColumn>
        <PropertyColumn Property="@(t => t.Duration)" Sortable="true" />
        <PropertyColumn Property="@(t => t.DisplaySize)" Sortable="true" />
        <TemplateColumn Title="Filename" Sortable="true" SortBy="SortFilename">
            <HeaderTemplate Context="col">
                <div class="filename-header">
                    <button type="button"
                            class="col-title"
                            @onclick="() => col.Grid.SortByColumnAsync(col)">
                        Filename
                    </button>
                    <a class="filename-customize-button"
                       href="/settings/file-name-templates"
                       title="Customize file name templates"
                       aria-label="Customize file name templates"
                       @onclick:stopPropagation="true">
                        <i class="e-icons e-edit"></i>
                    </a>
                </div>
            </HeaderTemplate>
            <ChildContent>
                @{ var filename = GetFileName(context); }
                <div class="cell-with-copy">
                    <span class="cell-with-copy-text">@filename</span>
                    @if (!string.IsNullOrEmpty(filename))
                    {
                        var copyState = GetFileNameCopyState(context);
                        <button type="button"
                                class="cell-copy-button"
                                title="Copy filename"
                                aria-label="Copy filename"
                                disabled="@copyState.IsDisabled"
                                @onclick="() => CopyFileNameToClipboard(context)"
                                @onclick:stopPropagation="true">
                            <i class="@copyState.IconClassName"></i>
                        </button>
                    }
                </div>
            </ChildContent>
        </TemplateColumn>
    </QuickGrid>
    </div>
}
