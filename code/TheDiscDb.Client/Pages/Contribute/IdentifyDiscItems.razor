@inherits CancellableComponentBase
@page "/contribution/{contributionId}/discs/{discId}/identify"

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@if (this.disc != null && this.contribution != null)
{
    <TheDiscDb.Client.Controls.Breadcrumb PrimaryText="Identify" Items="[
                                                                         GetRootContributionLink(),
                                                                         GetContributionLink(this.contribution),
                                                                         GetContributionDiscLink(this.contribution, this.disc)
                                                                     ]" />
}

<div class="contribute-layout identify-title-page">
    <section class="contribute-hero compact">
        <h1>Indentify Disc Items</h1>
        <p>Identify the items on this disc by providing titles and other information.</p>
        <p>You can edit the title by clicking on the title link. Once you have identified all items, click the "Done Identifying" button.</p>
    </section>

    @if (readOnlyDisc != null && readOnlyItem != null && readOnlyRelease != null)
    {
        <div class="alert alert-info">
            This disc was copied from an existing database disc. The details below will be updated from the source disc when you finish the contribution.
        </div>

        <section class="info-card mb-3">
            <h2>Existing disc view</h2>
            <dl class="row mb-0">
                <dt class="col-sm-3">Media item</dt>
                <dd class="col-sm-9">@readOnlyItem.Title (@readOnlyItem.Year)</dd>

                <dt class="col-sm-3">Release</dt>
                <dd class="col-sm-9">@readOnlyRelease.Title</dd>

                <dt class="col-sm-3">Disc</dt>
                <dd class="col-sm-9">@readOnlyDisc.Name · @readOnlyDisc.Format</dd>

                <dt class="col-sm-3">Content hash</dt>
                <dd class="col-sm-9"><code>@disc?.ContentHash</code></dd>
            </dl>
        </section>

        <section class="info-card mb-3">
            <h2>Disc titles</h2>
            @if (readOnlyTitles != null && readOnlyTitles.Any())
            {
                <QuickGrid Items="readOnlyTitles" Class="striped-grid">
                    <PropertyColumn Property="@(t => t.Index)" Title="#" />
                    <PropertyColumn Property="@(t => t.SourceFile)" Title="Source File" />
                    <PropertyColumn Property="@(t => t.Description)" Title="Description" />
                    <PropertyColumn Property="@(t => t.ItemType)" Title="Type" />
                    <PropertyColumn Property="@(t => t.Season)" Title="Season" />
                    <PropertyColumn Property="@(t => t.Episode)" Title="Episode" />
                    <PropertyColumn Property="@(t => t.SegmentMap)" Title="Segment Map" />
                    <PropertyColumn Property="@(t => t.Duration)" Title="Duration" />
                    <PropertyColumn Property="@(t => t.DisplaySize)" Title="Size" />
                    <TemplateColumn Title="Filename">
                        @GetReadOnlyFileName(context)
                    </TemplateColumn>
                </QuickGrid>
            }
            else
            {
                <p>No title data is available for this copied disc yet.</p>
            }
        </section>

        <div class="cta-row split">
            <a class="e-btn e-primary" href="/contribution/@ContributionId">Back to contribution</a>
        </div>
    }
    else if (!string.IsNullOrEmpty(loadError))
    {
        <div class="alert alert-warning">
            @loadError
            <a class="ms-2" href="/contribution/@ContributionId">Back to contribution</a>
        </div>
    }
    else if (allTitles is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="filter-panel">
            <h3 class="filter-panel-heading">Filters</h3>
            <div class="filter-controls">
                @if (sortedUniqueLengths.Length >= 2)
                {
                    <div class="filter-group length-filter">
                        <div class="filter-label-row">
                            <label>Length: @FormatSecondsToLength(sortedUniqueLengths[lengthRange[0]]) – @FormatSecondsToLength(sortedUniqueLengths[lengthRange[1]])</label>
                            <SfButton CssClass="e-small e-flat" IconCss="e-icons e-undo" OnClick="ResetLengthFilter" title="Reset length filter" />
                        </div>
                        <SfSlider TValue="int[]" Value="@lengthRange" Type="SliderType.Range"
                                  Min="0" Max="@(sortedUniqueLengths.Length - 1)"
                                  ValueChanged="OnLengthRangeChanged">
                            <SliderEvents TValue="int[]" OnTooltipChange="OnLengthTooltipChange" />
                            <SliderTooltip IsVisible="true" ShowOn="TooltipShowOn.Always" Placement="TooltipPlacement.Before" />
                        </SfSlider>
                    </div>
                }
                <div class="filter-group search-filter">
                    <SfTextBox Placeholder="Search all fields..." Value="@searchText" Input="OnSearchInput"
                               ValueChange="OnSearchValueChange"
                               CssClass="e-field" ShowClearButton="true" />
                </div>
                <div class="filter-group reset-sort-group">
                    <SfButton Disabled="@(!this.hasCustomSort)" OnClick="ResetSort">Reset sort</SfButton>
                </div>
            </div>
        </div>

        <QuickGrid @key="this.quickGridVersion" Items="filteredTitles" Class="striped-grid">
            <PropertyColumn Property="@(t => t.ChapterCount)" Sortable="true">
                <HeaderTemplate Context="col">
                    <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                        <span class="col-title-text">ChapterCount</span>
                        <span class="sort-indicator" aria-hidden="true"></span>
                    </button>
                </HeaderTemplate>
            </PropertyColumn>
            <TemplateColumn Title="Display Size" Sortable="true" SortBy="SortDisplaySize">
                <HeaderTemplate Context="col">
                    <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                        <span class="col-title-text">Display Size</span>
                        <span class="sort-indicator" aria-hidden="true"></span>
                    </button>
                </HeaderTemplate>
                <ChildContent>
                    @context.DisplaySize
                </ChildContent>
            </TemplateColumn>
            <TemplateColumn Title="Length" Sortable="true" SortBy="SortDuration">
                <HeaderTemplate Context="col">
                    <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                        <span class="col-title-text">Length</span>
                        <span class="sort-indicator" aria-hidden="true"></span>
                    </button>
                </HeaderTemplate>
                <ChildContent>
                    @context.Length
                </ChildContent>
            </TemplateColumn>
            <TemplateColumn Title="Segment Map" Sortable="true" SortBy="SortSegmentNumber">
                <HeaderTemplate Context="col">
                    <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                        <span class="col-title-text">Segment Map</span>
                        <span class="sort-indicator" aria-hidden="true"></span>
                    </button>
                </HeaderTemplate>
                <ChildContent>
                    <span title="@context.SegmentMap">@Truncate(context.SegmentMap, 12)</span>
                </ChildContent>
            </TemplateColumn>
            <TemplateColumn Title="Playlist" Sortable="true" SortBy="SortPlaylistNumber">
                <HeaderTemplate Context="col">
                    <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                        <span class="col-title-text">Playlist</span>
                        <span class="sort-indicator" aria-hidden="true"></span>
                    </button>
                </HeaderTemplate>
                <ChildContent>
                    @context.Playlist
                </ChildContent>
            </TemplateColumn>
            @if (this.commentColumnVisible)
            {
                <PropertyColumn Property="@(t => t.JavaComment)" Title="Comment" Sortable="true">
                    <HeaderTemplate Context="col">
                        <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                            <span class="col-title-text">Comment</span>
                            <span class="sort-indicator" aria-hidden="true"></span>
                        </button>
                    </HeaderTemplate>
                </PropertyColumn>
            }
            <TemplateColumn Title="Name" Sortable="true" SortBy="SortName">
                <HeaderTemplate Context="col">
                    <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                        <span class="col-title-text">Name</span>
                        <span class="sort-indicator" aria-hidden="true"></span>
                    </button>
                </HeaderTemplate>
                <ChildContent>
                    <a title="edit" style="cursor:pointer" @onclick="() => EditTitle(context)">@GetTitle(context)</a>
                </ChildContent>
            </TemplateColumn>
            @if (this.mediaType != null && this.mediaType.Equals("series", StringComparison.InvariantCultureIgnoreCase))
            {
                <TemplateColumn Title="Season" Align="Align.Center">
                    @GetSeason(context)
                </TemplateColumn>
                <TemplateColumn Title="Episode" Align="Align.Center">
                    @GetEpisode(context)
                </TemplateColumn>
            }
            <TemplateColumn Title="Type" Sortable="true" SortBy="SortType">
                <HeaderTemplate Context="col">
                    <button type="button" class="col-title" @onclick="() => SortColumnAsync(col)">
                        <span class="col-title-text">Type</span>
                        <span class="sort-indicator" aria-hidden="true"></span>
                    </button>
                </HeaderTemplate>
                <ChildContent>
                    @if (IsIdentified(context))
                    {
                        <span>@GetIdentifyButtonText(context)</span>
                    }
                    else
                    {
                        <SfDropDownButton Content="Identify">
                            <DropDownButtonEvents ItemSelected="(args) => ItemSelected(context, args)"></DropDownButtonEvents>
                            <DropDownMenuItems>
                                @if (this.mediaType != null && this.mediaType.Equals("movie", StringComparison.InvariantCultureIgnoreCase))
                                {
                                    <DropDownMenuItem Text="Main Movie" data-type="MainMovie"></DropDownMenuItem>
                                }
                                @if (this.mediaType != null && this.mediaType.Equals("series", StringComparison.InvariantCultureIgnoreCase))
                                {
                                    <DropDownMenuItem Text="Episode" data-type="Episode"></DropDownMenuItem>
                                }
                                <DropDownMenuItem Text="Extra" data-type="Extra"></DropDownMenuItem>
                                <DropDownMenuItem Text="Deleted Scene" data-type="DeletedScene"></DropDownMenuItem>
                                <DropDownMenuItem Text="Trailer" data-type="Trailer"></DropDownMenuItem>
                                <DropDownMenuItem Text="Featurette" data-type="Featurette"></DropDownMenuItem>
                                <DropDownMenuItem Text="Interview" data-type="Interview"></DropDownMenuItem>
                                <DropDownMenuItem Text="Scene" data-type="Scene"></DropDownMenuItem>
                                <DropDownMenuItem Text="Music" data-type="Music"></DropDownMenuItem>
                                <DropDownMenuItem Text="Short" data-type="Short"></DropDownMenuItem>
                                <DropDownMenuItem Text="Other" data-type="Other"></DropDownMenuItem>
                            </DropDownMenuItems>
                        </SfDropDownButton>
                    }
                </ChildContent>
            </TemplateColumn>
            <TemplateColumn Align="Align.Center">
                @if (IsIdentified(context))
                {
                    <SfButton IconCss="e-icons e-circle-remove" OnClick="() => RemoveIdentification(context)" title="Remove Identification" />
                }
                else
                {
                    <span>&nbsp;</span>
                }
            </TemplateColumn>
            <TemplateColumn Align="Align.Center">
                @if (IsIdentified(context) && HasAudioSegments(context))
                {
                    <SfButton IconCss="@GetAudioIconCss(context)" OnClick="() => NameAudioTracks(context)" title="@GetAudioButtonToolTip(context)" />
                }
                else
                {
                    <span>&nbsp;</span>
                }
            </TemplateColumn>
            <TemplateColumn Align="Align.Center">
                @if (IsIdentified(context) && context.ChapterCount > 1)
                {
                    <SfButton IconCss="@GetChapterIconCss(context)" OnClick="() => InputChapters(context)" title="@GetChapterButtonToolTip(context)" />
                }
                else
                {
                    <span>&nbsp;</span>
                }
            </TemplateColumn>
        </QuickGrid>

        <div class="cta-row split">
            <a class="e-btn e-outline" href="/contribution/@ContributionId/discs/@DiscId/naming?popup=1" target="_blank" rel="noopener noreferrer">Open Naming Helper</a>
            <button class="e-btn e-primary" @onclick="SubmitIdentifications" disabled="@IsDoneButtonDisabled">Done Identifying</button>
        </div>
    }
</div>


@if (showEpisodeDialog)
{
    <SfDialog @ref="episodeDialog" Target="body" Width="390px" @bind-Visible="@showEpisodeDialog" CssClass="e-edit-dialog" IsModal="true" ShowCloseIcon="true" Header="Identify Episode">
        <ChildContent>
            <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
            <EditForm Model="@currentItem" OnValidSubmit="@HandleValidEpisodeSubmit">
                <DataAnnotationsValidator></DataAnnotationsValidator>
                <div class="field-container name-container">
                    <SfTextBox CssClass="season-number e-field" Placeholder="Season Number" OnChange="TrySetEpisodeTitle" FloatLabelType="@FloatLabelType.Always" @bind-Value="@currentItem!.Episode!.Season"></SfTextBox>
                    <ValidationMessage For="@(() => currentItem!.Episode!.Season)" />
                </div>
                <div class="field-container name-container">
                    <SfTextBox CssClass="episode-number e-field" Placeholder="Episode Number" OnChange="TrySetEpisodeTitle" FloatLabelType="@FloatLabelType.Always" @bind-Value="@currentItem.Episode.Episode"></SfTextBox>
                    <ValidationMessage For="@(() => currentItem.Episode.Episode)" />
                </div>
                <div class="field-container name-container">
                    <SfTextBox CssClass="item-title e-field" Placeholder="Title" FloatLabelType="@FloatLabelType.Always" @onkeypress="EpisodeTitleKeyPress" @bind-Value="@currentItem!.ItemTitle"></SfTextBox>
                    <ValidationMessage For="@(() => currentItem!.ItemTitle)" />
                </div>
                <div class="field-container name-container">
                    <SfTextBox CssClass="episode-description e-field" Placeholder="Description (optional)" FloatLabelType="@FloatLabelType.Always" @bind-Value="@currentItem.Description"></SfTextBox>
                    <ValidationMessage For="@(() => currentItem.Description)" />
                </div>
                <div class="e-footer-content">
                    <div class="button-container">
                        <button type="button" class="e-btn e-normal" @onclick="EpisodeDialogCancelClicked">Cancel</button>
                        <button type="submit" class="e-btn e-normal e-primary">Save</button>
                    </div>
                </div>
            </EditForm>
        </ChildContent>
    </SfDialog>
}

@if (showItemDialog)
{
    <SfDialog @ref="itemDialog" Target="body" Width="390px" @bind-Visible="@showItemDialog" CssClass="e-edit-dialog" IsModal="true" ShowCloseIcon="true" Header="Identify Item">
        <ChildContent>
            <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
            <EditForm Model="@currentItem" OnValidSubmit="@HandleValidItemSubmit">
                <DataAnnotationsValidator></DataAnnotationsValidator>
                <div class="field-container name-container">
                    <SfTextBox CssClass="item-title e-field" Placeholder="Title" FloatLabelType="@FloatLabelType.Always" @bind-Value="@currentItem!.ItemTitle"></SfTextBox>
                    <ValidationMessage For="@(() => currentItem!.ItemTitle)" />
                </div>
                @if (this.mediaType != null && this.mediaType.Equals("series", StringComparison.InvariantCultureIgnoreCase))
                {
                    <div class="field-container name-container">
                        <SfTextBox CssClass="season-number e-field" Placeholder="Season Number (optional)" FloatLabelType="@FloatLabelType.Always" @bind-Value="@currentItem!.Episode!.Season"></SfTextBox>
                        <ValidationMessage For="@(() => currentItem!.Episode!.Season)" />
                    </div>
                    <div class="field-container name-container">
                        <SfTextBox CssClass="episode-number e-field" Placeholder="Episode Number (optional)" FloatLabelType="@FloatLabelType.Always" @bind-Value="@currentItem.Episode.Episode"></SfTextBox>
                        <ValidationMessage For="@(() => currentItem.Episode.Episode)" />
                    </div>
                }
                <div class="field-container name-container">
                    <SfTextBox CssClass="item-description e-field" Placeholder="Description (optional)" FloatLabelType="@FloatLabelType.Always" @bind-Value="@currentItem.Description"></SfTextBox>
                    <ValidationMessage For="@(() => currentItem.Description)" />
                </div>
                <div class="e-footer-content">
                    <div class="button-container">
                        <button type="button" class="e-btn e-normal" @onclick="ItemDialogCancelClicked">Cancel</button>
                        <button type="submit" class="e-btn e-normal e-primary">Save</button>
                    </div>
                </div>
            </EditForm>
        </ChildContent>
    </SfDialog>
}

@if (showChapterDialog)
{
    <SfDialog @ref="chapterDialog" Target="body" Width="400px" @bind-Visible="@showChapterDialog" CssClass="e-edit-dialog" IsModal="true" ShowCloseIcon="true" Header="Input Chapters">
        <ChildContent>
            <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
            <EditForm Model="@currentItem" OnValidSubmit="@HandleValidChapterSubmit">
                <DataAnnotationsValidator></DataAnnotationsValidator>
                @if (this.currentItem != null && this.currentItem.ChapterMatches.Any())
                {
                    <SfDropDownButton Content="Copy From...">
                        <DropDownButtonEvents ItemSelected="(args) => CopyChapters(args)"></DropDownButtonEvents>
                        <DropDownMenuItems>
                            @for (int i = 0; i < this.currentItem.ChapterMatches.Count; i++)
                            {
                                var match = this.currentItem.ChapterMatches.ElementAt(i);
                                for (int j = 0; j < match.Value.Count(); j++)
                                {
                                    var discItem = match.Value.ElementAt(j);
                                    var name = $"{match.Key.Name} {discItem.Name}";
                                    <DropDownMenuItem Text="@name" data-matchIndex="@i" data-ItemIndex="@j"></DropDownMenuItem>
                                }
                            }
                        </DropDownMenuItems>
                    </SfDropDownButton>
                }
                @if (this.clipboardHasChapters)
                {
                    <button type="button" class="e-btn e-normal" @onclick="PasteChaptersFromClipboard">Paste from Clipboard</button>
                }
                @if (!string.IsNullOrEmpty(this.clipboardWarning))
                {
                    <div class="alert alert-warning" role="alert">@this.clipboardWarning</div>
                }
                <ol>
                    @foreach (var item in this.currentItem!.Chapters)
                    {
                        <li>
                            <InputText @bind-Value="item.Title" class="form-control" />
                        </li>
                    }
                </ol>
                <div class="e-footer-content">
                    <div class="button-container">
                        <button type="button" class="e-btn e-normal" @onclick="ChapterDialogCancelClicked">Cancel</button>
                        <button type="submit" class="e-btn e-normal e-primary">Save</button>
                    </div>
                </div>
            </EditForm>
        </ChildContent>
    </SfDialog>
}

@if (showAudioTrackDialog)
{
    <SfDialog @ref="audioTrackDialog" Target="body" Width="400px" @bind-Visible="@showAudioTrackDialog" CssClass="e-edit-dialog" IsModal="true" ShowCloseIcon="true" Header="Name Audio Tracks">
        <ChildContent>
            <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
            <EditForm Model="@currentItem" OnValidSubmit="@HandleValidAudioTrackSubmit">
                <DataAnnotationsValidator></DataAnnotationsValidator>
                <ol>
                    @foreach (var item in this.currentItem!.AudioTracks)
                    {
                        <li>
                            <div>@item.GetDisplayName()</div>
                            <InputText @bind-Value="item.Title" class="form-control" />
                        </li>
                    }
                </ol>

                <div class="e-footer-content">
                    <div class="button-container">
                        <button type="button" class="e-btn e-normal" @onclick="AudioTrackDialogCancelClicked">Cancel</button>
                        <button type="submit" class="e-btn e-normal e-primary">Save</button>
                    </div>
                </div>
            </EditForm>
        </ChildContent>
    </SfDialog>
}


<Syncfusion.Blazor.Popups.SfDialogProvider />

<div class="col-lg-12 control-section toast-default-section">
    <SfToast ID="toast_default" @ref="toast" Title="User Message" Content="@toastContent" Timeout="5000" Icon="e-meeting">
        <ToastPosition X="Right"></ToastPosition>
    </SfToast>
</div>