@inherits CancellableComponentBase
@page "/contribution/{contributionId}"
@using Syncfusion.Blazor.Popups
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@if (Contribution is not null)
{
    <TheDiscDb.Client.Controls.Breadcrumb PrimaryText="@GetContributionLinkText(Contribution)" Items="[GetRootContributionLink()]" />

    @if (Contribution.Boxset is not null)
    {
        <div class="alert alert-info" role="status">
            <strong>Part of boxset:</strong> @Contribution.Boxset.Title.
            <a href="@($"/contribution/boxset/{Contribution.Boxset.EncodedId}")" class="ms-2">Back to boxset</a>
        </div>
    }

    <div class="contribute-layout contribution-discs-page">
        <section class="contribute-hero compact">
            <h1>@Contribution.Title (@Contribution.Year)</h1>
            <p>Review the release summary, manage discs, and complete the submission when everything looks good.</p>
        </section>

        <section class="info-grid single-column">
            <article class="info-card release-summary-card">
                <div class="release-summary">
                    <div class="cover-stack">
                        @if (!string.IsNullOrEmpty(Contribution.FrontImageUrl))
                        {
                            <img src="@GetDirectImageUrl(Contribution.FrontImageUrl)" width="180" height="260" alt="Front cover" class="cover" />
                        }
                        @if (!string.IsNullOrEmpty(Contribution.BackImageUrl))
                        {
                            <img src="@GetDirectImageUrl(Contribution.BackImageUrl)" width="120" height="170" alt="Back cover" class="cover secondary" />
                        }
                    </div>
                    <dl>
                        <dt>Release title</dt>
                        <dd>@Contribution.ReleaseTitle</dd>

                        <dt>Release date</dt>
                        <dd>@string.Format("{0:yyyy-MM-dd}", Contribution.ReleaseDate)</dd>

                        <dt>Locale / Region</dt>
                        <dd>@Contribution.Locale · @(string.IsNullOrEmpty(Contribution.RegionCode) ? "N/A" : Contribution.RegionCode)</dd>

                        @if (!string.IsNullOrEmpty(Contribution.Asin))
                        {
                            <dt>ASIN</dt>
                            <dd>@Contribution.Asin</dd>
                        }

                        @if (!string.IsNullOrEmpty(Contribution.Upc))
                        {
                            <dt>UPC</dt>
                            <dd>@Contribution.Upc</dd>
                        }

                        @if (!string.IsNullOrEmpty(Contribution.ExternalProvider))
                        {
                            <dt>External provider</dt>
                            <dd>@Contribution.ExternalProvider (@Contribution.ExternalId)</dd>
                        }

                        <dt>Status</dt>
                        <dd><span class="badge bg-@GetStatusBadgeClass()">@Contribution.Status</span></dd>
                        @if (IsEditable)
                        {
                            <a href="/contribution/@ContributionId/edit" class="edit-link" title="Edit release details"><i class="e-icons e-edit"></i> Edit release details</a>
                        }
                    </dl>
                </div>
            </article>
        </section>

        <section class="info-card discs-card">
            <div class="section-header">
                <h2>Discs in this release</h2>
                <a class="btn btn-accent btn-large" href="/contribution/@ContributionId/AddDisc">
                    <span class="btn-icon">+</span>
                    Add Disc
                </a>
            </div>

            @if (discList is { Count: > 0 })
            {
                <table class="striped-grid contribute-grid disc-reorder-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Format</th>
                            <th>Logs</th>
                            <th></th>
                            @if (IsEditable)
                            {
                                <th class="drag-col"></th>
                            }
                        </tr>
                    </thead>
                    <tbody @ref="tableBodyRef">
                        @for (int i = 0; i < discList.Count; i++)
                        {
                            var disc = discList[i];
                            var rowIndex = i;
                            <tr class="@GetRowClass(disc)"
                                data-row-index="@rowIndex"
                                draggable="@IsEditable.ToString().ToLowerInvariant()"
                                @ondragstart="() => OnDragStart(disc)"
                                @ondragenter="() => OnDragEnter(disc)"
                                @ondragover:preventDefault="true"
                                @ondragend="OnDragEnd">
                                <td>
                                    <div class="disc-name">
                                        <a href="@GetDiscTargetUrl(disc)" title="Open Disc">@disc.Name</a>
                                    </div>
                                </td>
                                <td>@disc.Format</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(disc.ExistingDiscPath))
                                    {
                                        <span class="badge bg-light text-dark">Copied from matching disc</span>
                                        <div class="text-muted small">@GetCopiedFromSummary(disc)</div>
                                    }
                                    else
                                    {
                                        <span>@(disc.LogsUploaded ? "Uploaded" : "Pending")</span>
                                    }
                                </td>
                                <td>
                                    <a href="@($"/contribution/{ContributionId}/disc/{disc.EncodedId}/edit?returnUrl=/contribution/{ContributionId}")" title="Edit disc details"><i class="e-icons e-edit"></i> Edit</a>
                                    @if (IsEditable)
                                    {
                                        <button type="button" class="btn btn-sm ms-2" title="Delete disc" @onclick="() => ConfirmDeleteDisc(disc)">
                                            <i class="e-icons e-trash"></i>
                                        </button>
                                    }
                                </td>
                                @if (IsEditable)
                                {
                                    <td class="drag-handle" data-drag-handle title="Drag to reorder">⋮</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>

        <div class="cta-row split">
            <a class="btn btn-secondary" href="/contribute/@Contribution.MediaType!.ToLowerInvariant()">Back to release details</a>
            <a class="btn btn-outline-primary" href="/contribution/@ContributionId/messages">Messages</a>
            <button class="btn btn-primary" @onclick="NavigateToReview" disabled="@IsCompleteButtonDisabled">Complete Contribution</button>
        </div>
    </div>
}
else
{
    <div class="contribute-layout">
        <section class="contribute-hero compact">
            <h1>Loading Contribution...</h1>
        </section>
    </div>
}

@if (showDeleteDiscDialog)
{
    <SfDialog Target="body" Width="400px" @bind-Visible="@showDeleteDiscDialog" CssClass="e-edit-dialog" IsModal="true" ShowCloseIcon="true" Header="Delete Disc">
        <ChildContent>
            <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
            <p>Delete disc <strong>@deletingDisc?.Name</strong> from this contribution?</p>
            <p class="text-muted">This will remove the disc and any identified items saved under it.</p>
            @if (!string.IsNullOrEmpty(deleteDiscErrorMessage))
            {
                <div class="alert alert-danger mt-2">@deleteDiscErrorMessage</div>
            }
            <div class="e-footer-content">
                <div class="button-container">
                    <button type="button" class="e-btn e-normal" @onclick="CancelDeleteDisc" disabled="@isDeletingDisc">Cancel</button>
                    <button type="button" class="e-btn e-normal e-danger" @onclick="ExecuteDeleteDisc" disabled="@isDeletingDisc">
                        @if (isDeletingDisc)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </ChildContent>
    </SfDialog>
}

<Syncfusion.Blazor.Popups.SfDialogProvider />