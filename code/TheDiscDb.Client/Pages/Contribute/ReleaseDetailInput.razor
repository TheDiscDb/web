@page "/contribute/{mediaType}/{externalId}"

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@if (this.externalData != null)
{
    <TheDiscDb.Client.Controls.Breadcrumb PrimaryText="@BreadcrumbText" Items="[
        GetRootContributionLink()
    ]" />
}

<div class="contribute-layout identify-title-page">
    <section class="contribute-hero compact">
        <p class="eyebrow">Step 2 · Add Release Details</p>
        <h1>Release Details</h1>
        <p>We recommend getting most of these details from the Amazon product page for this release if you can.</p>
    </section>

    @if (!string.IsNullOrEmpty(BoxsetId))
    {
        <div class="alert alert-info" role="status">
            <strong>Part of boxset:</strong> @(boxsetTitle ?? BoxsetId).
            We've prefilled fields shared with the boxset (release title, slug, date, region, etc.) — feel free to adjust them.
            <a href="@($"/contribute/{MediaType}/{ExternalId}")" class="ms-2">Create as a standalone contribution instead</a>
        </div>
    }

<EditForm Model="@form" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>ASIN<span class="required">*</span></label>
        <InputText class="form-control" @bind-Value="form!.Asin" @oninput="OnAsinInput" />
        <ValidationMessage For="@(() => form!.Asin)" />
        @* Amazon import disabled — Amazon blocks server-side scraping from cloud IPs.
           TODO: Replace with Amazon Creators API when available. *@
    </div>
    <div class="mb-3">
        <label>UPC/EAN<span class="required">*</span></label>
        <InputText class="form-control" @bind-Value="form!.Upc" />
        <ValidationMessage For="@(() => form!.Upc)" />
    </div>
    <div class="mb-3">
        <label>Release Date<span class="required">*</span></label>
        <InputText class="form-control" @bind-Value="releaseDate" @oninput="ReleaseDateChanged" />
        @* <SfDatePicker TValue="DateTimeOffset" class="form-control" Placeholder='Choose a Release Date or paste from Amazon' @bind-Value="request.ReleaseDate" OnInput="ReleaseDateChanged"></SfDatePicker> *@
        <div class="validation-message">@releaseDateValidationMessage</div>
    </div>
    <div class="mb-3">
        <label>Front Image<span class="required">*</span></label>
        <div class="hstack gap-3 align-items-start">
            <SfUploader @ref="frontImageUploader" AutoUpload="true" ShowFileList="true" AllowMultiple="false" AllowedExtensions=".jpg, .jpeg">
                <UploaderButtons Browse="Browse"></UploaderButtons>
                <UploaderEvents FileSelected="FrontImageSelected" Success="FrontImageUploadSuccess" BeforeRemove="BeforeFrontImageRemove" OnRemove="FrontImageRemoved"></UploaderEvents>
                <UploaderAsyncSettings SaveUrl="@frontImageUploadUrl" RemoveUrl="@frontImageRemoveUrl"></UploaderAsyncSettings>
            </SfUploader>
            <span id="frontImagePreview">
                @if (!string.IsNullOrEmpty(frontImagePreviewUrl))
                {
                    <img src="@frontImagePreviewUrl" width="156" height="231" alt="Front cover preview" />
                }
            </span>
        </div>
        <ValidationMessage For="@(() => form!.FrontImageUrl)" />
    </div>
    <div class="mb-3">
        <label>Back Image</label>
        <div class="hstack gap-3 align-items-start">
        <SfUploader @ref="backImageUploader" AutoUpload="true" ShowFileList="true" AllowMultiple="false" AllowedExtensions=".jpg, .jpeg">
            <UploaderButtons Browse="Browse"></UploaderButtons>
                <UploaderEvents FileSelected="BackImageSelected" Success="BackImageUploadSuccess" BeforeRemove="BeforeBackImageRemove" OnRemove="BackImageRemoved"></UploaderEvents>
            <UploaderAsyncSettings SaveUrl="@backImageUploadUrl" RemoveUrl="@backImageRemoveUrl"></UploaderAsyncSettings>
        </SfUploader>
            <span id="backImagePreview">
                @if (!string.IsNullOrEmpty(backImagePreviewUrl))
                {
                    <img src="@backImagePreviewUrl" width="156" height="231" alt="Back cover preview" />
                }
            </span>
        </div>
        <ValidationMessage For="@(() => form!.BackImageUrl)" />
    </div>
    <div class="mb-3">
        <label>Release Title<span class="required">*</span></label>
        <InputText class="form-control" @bind-Value="form!.ReleaseTitle" @oninput="ReleaseTitleChanged" />
        <ValidationMessage For="@(() => form!.ReleaseTitle)" />
    </div>
    <div class="mb-3">
        <label>Release Slug<span class="required">*</span></label>
        <InputText class="form-control" @bind-Value="form!.ReleaseSlug" />
        <ValidationMessage For="@(() => form!.ReleaseSlug)" />
    </div>
    <div class="mb-3">
        <label>Locale</label>
        <InputText class="form-control" @bind-Value="form!.Locale" />
        <ValidationMessage For="@(() => form!.Locale)" />
    </div>
    <div class="mb-3">
        <label>Region Code</label>
        <InputText class="form-control" @bind-Value="form!.RegionCode" />
        <ValidationMessage For="@(() => form!.RegionCode)" />
    </div>
    @if (!string.IsNullOrEmpty(submitErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@submitErrorMessage</div>
    }
    <div class="cta-row split">
        <a class="btn btn-secondary" href="/contribute/@this.MediaType">Back</a>
        <button type="submit" class="btn btn-primary">Save Release Details</button>
    </div>
</EditForm>

<div class="col-lg-12 control-section toast-default-section">
    <SfToast ID="toast_default" @ref="toast" Title="User Message" Content="@toastContent" Timeout="5000" Icon="e-meeting">
        <ToastPosition X="Right"></ToastPosition>
    </SfToast>
</div>
</div>