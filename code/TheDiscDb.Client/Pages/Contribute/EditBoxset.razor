@inherits CancellableComponentBase
@page "/contribution/boxset/{BoxsetId}/edit"

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="Edit Boxset" Items='[("Home", "/"), ("Contribute", "/contribute"), ("My Contributions", "/contribute/my")]' />

<div class="contribute-layout">
    @if (isLoading)
    {
        <section class="info-card">
            <p>Loading boxset...</p>
        </section>
    }
    else if (!boxsetFound)
    {
        <section class="info-card">
            <div class="alert alert-danger">@(errorMessage ?? "Boxset not found.")</div>
            <a class="btn btn-secondary" href="/contribute/my">Back to My Contributions</a>
        </section>
    }
    else
    {
        <section class="contribute-hero compact">
            <h1>Edit Boxset</h1>
            <p>Update the metadata for this boxset. Cover images and members are managed on the boxset page.</p>
        </section>

        <section class="info-card">
            <EditForm Model="request" OnValidSubmit="HandleSubmit" FormName="EditBoxsetForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Boxset Title <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="request.Title" @oninput="OnTitleChanged" />
                    <ValidationMessage For="@(() => request.Title)" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Slug <span class="text-danger">*</span></label>
                    <InputText class="form-control" @bind-Value="request.Slug" />
                    <ValidationMessage For="@(() => request.Slug)" />
                    <small class="text-muted">URL-friendly identifier for the boxset.</small>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">ASIN <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="request.Asin" />
                        <ValidationMessage For="@(() => request.Asin)" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">UPC / EAN <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="request.Upc" />
                        <ValidationMessage For="@(() => request.Upc)" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Locale</label>
                        <InputText class="form-control" @bind-Value="request.Locale" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Region Code</label>
                        <InputText class="form-control" @bind-Value="request.RegionCode" />
                    </div>
                </div>

                <TheDiscDb.Client.Controls.ReleaseDateInput @ref="releaseDateInput" @bind-Value="request.ReleaseDate" Required="true" />
                <ValidationMessage For="@(() => request.ReleaseDate)" />

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Save Changes
                    </button>
                    <a class="btn btn-secondary" href="/contribution/boxset/@BoxsetId">Cancel</a>
                </div>
            </EditForm>
        </section>
    }
</div>
