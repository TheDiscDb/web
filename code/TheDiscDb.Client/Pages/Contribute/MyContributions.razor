@page "/contribute/my"
@using TheDiscDb.Client.Contributions
@using Syncfusion.Blazor.Popups

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="My Contributions" Items="[
    GetRootContributionLink()
]" />

<h1>My Contributions</h1>

<div class="mb-3" style="max-width: 300px;">
    <label class="form-label">Filter by Status</label>
    <select class="form-select" value="@StatusFilter" @onchange="OnStatusFilterChanged">
        <option value="">All</option>
        @foreach (var status in Enum.GetValues<UserContributionStatus>())
        {
            <option value="@status">@status</option>
        }
    </select>
</div>

<QuickGrid Items="Contributions" Class="striped-grid" ItemKey="@(c => c.EncodedId)">
    <TemplateColumn Title="Name">
        <a href="/contribution/@context.EncodedId">@context.ReleaseTitle</a>
    </TemplateColumn>
    <PropertyColumn Property="@(c => c.Title)" />
    <PropertyColumn Property="@(c => c.MediaType)" />
    <PropertyColumn Property="@(c => c.Status)" />
    <TemplateColumn Title="">
        <button class="btn btn-sm btn-outline-danger"
                disabled="@(!CanDelete(context))"
                @onclick="() => ConfirmDelete(context)"
                title="@(CanDelete(context) ? "Delete contribution" : "Only Pending, Rejected, or Changes Requested contributions can be deleted")">
            🗑
        </button>
    </TemplateColumn>
</QuickGrid>

@if (TotalPages > 1)
{
    <nav class="mt-3 d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasPreviousPage)" @onclick="GoToPreviousPage" title="Previous page">
            &lsaquo;
        </button>
        <span>Page @CurrentPage of @TotalPages</span>
        <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasNextPage)" @onclick="GoToNextPage" title="Next page">
            &rsaquo;
        </button>
    </nav>
}

<SfDialog @bind-Visible="@showDeleteDialog" Width="400px" IsModal="true" ShowCloseIcon="true" Header="Delete Contribution">
    <ChildContent>
        <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
        <p>Are you sure you want to delete the contribution <strong>@deletingContribution?.ReleaseTitle</strong>?</p>
        <p class="text-muted">This action cannot be undone.</p>
        @if (!string.IsNullOrEmpty(deleteErrorMessage))
        {
            <div class="alert alert-danger mt-2">@deleteErrorMessage</div>
        }
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn btn-secondary" @onclick="CancelDelete" disabled="@isDeleting">Cancel</button>
            <button class="btn btn-danger" @onclick="ExecuteDelete" disabled="@isDeleting">
                @if (isDeleting)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                }
                Delete
            </button>
        </div>
    </ChildContent>
</SfDialog>

<Syncfusion.Blazor.Popups.SfDialogProvider />