@page "/contribute/my"
@using TheDiscDb.Client.Contributions
@using Syncfusion.Blazor.Popups

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="My Contributions" Items="[
    GetRootContributionLink()
]" />

<div class="contribute-layout">
    <div class="page-header">
        <h1>My Contributions</h1>
        <div class="page-header__sub">Track and manage your disc contributions and boxsets.</div>
    </div>

    <section class="info-card">
        <div class="d-flex align-items-end gap-3 mb-3 flex-wrap">
            <div style="max-width: 280px; flex: 1;">
                <label class="form-label mb-1">Filter by Status</label>
                <select class="form-select" value="@StatusFilter" @onchange="OnStatusFilterChanged">
                    <option value="">All</option>
                    @foreach (var status in Enum.GetValues<UserContributionStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
        </div>

        <QuickGrid Items="Items" Class="striped-grid" ItemKey="@(r => $"{(r.IsBoxset ? "b" : "c")}:{r.EncodedId}")">
            <TemplateColumn Title="Name">
                <a href="@context.DetailUrl">@context.Name</a>
            </TemplateColumn>
            <PropertyColumn Property="@(r => r.Title)" />
            <PropertyColumn Property="@(r => r.Type)" Title="Type" />
            <PropertyColumn Property="@(r => r.Status)" />
            <TemplateColumn Title="">
                @if (CanDelete(context))
                {
                    <SfButton IconCss="e-icons e-circle-remove" OnClick="() => ConfirmDelete(context)" title="@($"Delete {(context.IsBoxset ? "boxset" : "contribution")}")" />
                }
            </TemplateColumn>
        </QuickGrid>

        @if (TotalPages > 1)
        {
            <nav class="mt-3 d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasPreviousPage)" @onclick="GoToPreviousPage" title="Previous page">
                    &lsaquo;
                </button>
                <span>Page @CurrentPage of @TotalPages</span>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!HasNextPage)" @onclick="GoToNextPage" title="Next page">
                    &rsaquo;
                </button>
            </nav>
        }
    </section>
</div>

@if (showDeleteDialog)
{
    <SfDialog Target="body" Width="400px" @bind-Visible="@showDeleteDialog" CssClass="e-edit-dialog" IsModal="true" ShowCloseIcon="true" Header="@($"Delete {(deletingItem?.IsBoxset == true ? "Boxset" : "Contribution")}")">
        <ChildContent>
            <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
            <p>
                Are you sure you want to delete the @(deletingItem?.IsBoxset == true ? "boxset" : "contribution")
                <strong>@deletingItem?.Name</strong>?
            </p>
            <p class="text-muted">This action cannot be undone.</p>
            @if (!string.IsNullOrEmpty(deleteErrorMessage))
            {
                <div class="alert alert-danger mt-2">@deleteErrorMessage</div>
            }
            <div class="e-footer-content">
                <div class="button-container">
                    <button type="button" class="e-btn e-normal" @onclick="CancelDelete" disabled="@isDeleting">Cancel</button>
                    <button type="button" class="e-btn e-normal e-danger" @onclick="ExecuteDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </ChildContent>
    </SfDialog>
}

<Syncfusion.Blazor.Popups.SfDialogProvider />
