@page "/contribution/boxset/{BoxsetId}"
@using Syncfusion.Blazor.Popups

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<TheDiscDb.Client.Controls.Breadcrumb PrimaryText="@(Boxset?.Title ?? "Boxset")" Items='[("Home", "/"), ("Contribute", "/contribute"), ("My Contributions", "/contribute/my")]' />

<div class="contribute-layout">
    @if (isLoading)
    {
        <section class="info-card">
            <p>Loading boxset...</p>
        </section>
    }
    else if (Boxset == null)
    {
        <section class="info-card">
            <div class="alert alert-danger">Boxset not found.</div>
        </section>
    }
    else
    {
        <section class="contribute-hero compact">
            <h1>@Boxset.Title</h1>
            <p>Slug: <code>@Boxset.Slug</code> &middot; Status: <span class="badge bg-secondary">@Boxset.Status</span></p>
        </section>

        <section class="info-card">
            <h2>Boxset Members</h2>
            <p class="text-muted">Drag contributions to reorder. The disc index is computed from the order below.</p>

            @if (Members.Count == 0)
            {
                <div class="alert alert-info">No discs added yet. Add discs from your existing contributions.</div>
            }
            else
            {
                <div class="list-group mb-3">
                    @foreach (var member in Members.OrderBy(m => m.SortOrder))
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-bold">
                                    Disc @(member.SortOrder + 1): @member.Disc.Name
                                    <span class="badge bg-info ms-1">@member.Disc.Format</span>
                                </div>
                                <small class="text-muted">Slug: @member.Disc.Slug</small>
                            </div>
                            <div class="d-flex gap-1 align-items-center">
                                @if (CanModify)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" title="Move up"
                                            disabled="@(member.SortOrder == 0)"
                                            @onclick="() => MoveUp(member)">&#9650;</button>
                                    <button class="btn btn-sm btn-outline-secondary" title="Move down"
                                            disabled="@(member.SortOrder == Members.Count - 1)"
                                            @onclick="() => MoveDown(member)">&#9660;</button>
                                    <button class="btn btn-sm btn-outline-danger" title="Remove"
                                            @onclick="() => ConfirmRemove(member)">&#x2715;</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @if (CanModify)
            {
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-outline-primary" @onclick="ShowAddDialog">Add Discs from Contributions</button>
                </div>
            }
        </section>

        <section class="info-card mt-3">
            <h2>Boxset Details</h2>
            <div class="row">
                <div class="col-md-6">
                    <dl>
                        <dt>ASIN</dt><dd>@(Boxset.Asin ?? "—")</dd>
                        <dt>UPC</dt><dd>@(Boxset.Upc ?? "—")</dd>
                        <dt>Locale</dt><dd>@(Boxset.Locale ?? "—")</dd>
                        <dt>Region Code</dt><dd>@(Boxset.RegionCode ?? "—")</dd>
                    </dl>
                </div>
                <div class="col-md-6">
                    <dl>
                        <dt>Release Date</dt><dd>@(Boxset.ReleaseDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
                        <dt>Total Discs</dt><dd>@TotalDiscCount</dd>
                        <dt>Total Contributions</dt><dd>@Members.Count</dd>
                    </dl>
                </div>
            </div>
        </section>

        @if (CanModify)
        {
            <section class="mt-3">
                <div class="d-flex gap-2">
                    <a class="btn btn-primary" href="/contribution/boxset/@BoxsetId/review">Review &amp; Submit</a>
                    <a class="btn btn-secondary" href="/contribute/my">Back to My Contributions</a>
                </div>
            </section>
        }
    }
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

<SfDialog @bind-Visible="@showRemoveDialog" Width="400px" IsModal="true" ShowCloseIcon="true" Header="Remove Contribution">
    <ChildContent>
        <DialogAnimationSettings Effect="DialogEffect.Zoom"></DialogAnimationSettings>
        <p>Remove disc <strong>@removingMember?.Disc?.Name</strong> from this boxset?</p>
        <p class="text-muted">The contribution itself will not be deleted.</p>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn btn-secondary" @onclick="CancelRemove">Cancel</button>
            <button class="btn btn-danger" @onclick="ExecuteRemove">Remove</button>
        </div>
    </ChildContent>
</SfDialog>

<Syncfusion.Blazor.Popups.SfDialogProvider />
