<SfSplitButton IconCss="@state.IconCss"
                CssClass="e-small copy-split-button"
                Disabled="@state.IsDisabled"
                title="Copy chapters"
                aria-label="Copy chapters">
    <SplitButtonEvents Clicked="OnPrimaryClick" ItemSelected="OnItemSelected" />
    <DropDownMenuItems>
        @foreach (var formatName in ChapterFormatter.GetFormatNames())
        {
            <DropDownMenuItem Text="@($"Copy as {formatName}")" Id="@formatName" />
        }
    </DropDownMenuItems>
</SfSplitButton>
